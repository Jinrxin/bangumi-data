t/l/0e/b8/153030_crt_I6q10.jpg?r=1712667568","medium":"https://lain.bgm.tv/r/400/pic/crt/l/0e/b8/153030_crt_I6q10.jpg?r=1712667568"},"name":"堂島健吾","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/15/71/12483_prsn_pXYzu.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/15/71/12483_prsn_pXYzu.jpg","large":"https://lain.bgm.tv/pic/crt/l/15/71/12483_prsn_pXYzu.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/15/71/12483_prsn_pXYzu.jpg"},"name":"古川慎","short_summary":"古川 慎（ふるかわ まこと、1989年9月29日 - ）は、日本の男性声優。トイズファクトリー所属。\r\n熊本県出身。福岡スクールオブミュージック専門学校卒業。\r\n\r\n5歳の時に見た『新機動戦記ガンダムW』のヒイロ・ユイを充てた緑川光の声に憧れたことで声優への興味を持つようになった。その後中学生時代にスカパーのアニメ専門チャンネルを見てアニメ好きになったという。\r\n高校生の時、友達からもらった専門学校のパンフレットに緑川光が特別講師としてくることを見て、挑戦してみようと思い専門学校に通い始めた。\r\n\r\n趣味は雑貨屋めぐり、神社や寺などのパワースポットを巡ること。\r\n一番好きな食べ物はお好み焼き。キュウリとカリフラワーが苦手。\r\n好きなアーティストはL'Arc〜en〜Ciel、Mr.Children、ゴスペラーズ、GRANRODEO、BUMP OF CHICKEN。\r\n\r\n2011年にWebアニメ「武装中学生」吉野サトシ役で声優デビュー。\r\n2012年にアルバイトでPS3専用ソフト「白騎士物語」のモーションアクターを演じた経験を持つ。\r\n2016年、7月より声優の小林裕介と共にパーソナリティを務めるラジオ『なんでもヒーロー！ ゆっけとまーぼー』の放送を開始。\r\n2017年10月に開催された、初バースデーイベント「古川慎　秋の収穫祭2017」にて、2018年アーティスト活動を開始することを発表。\r\n2018年7月、Lantisより歌手デビュー。同年8月31日、6年間所属していたスペースクラフト・エンタテインメントを退所し、フリーでの活動期間を経て同年12月1日、トイズファクトリーに所属。","career":["artist","seiyu"],"id":12483,"type":1,"locked":false}],"type":1,"id":153030},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/5a/94/160755_crt_B5G5z.jpg?r=1720316421","grid":"https://lain.bgm.tv/r/200/pic/crt/l/5a/94/160755_crt_B5G5z.jpg?r=1720316421","large":"https://lain.bgm.tv/pic/crt/l/5a/94/160755_crt_B5G5z.jpg?r=1720316421","medium":"https://lain.bgm.tv/r/400/pic/crt/l/5a/94/160755_crt_B5G5z.jpg?r=1720316421"},"name":"吉口","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/4c/b9/31512_prsn_Z57Xv.jpg?r=1551440055","grid":"https://lain.bgm.tv/r/200/pic/crt/l/4c/b9/31512_prsn_Z57Xv.jpg?r=1551440055","large":"https://lain.bgm.tv/pic/crt/l/4c/b9/31512_prsn_Z57Xv.jpg?r=1551440055","medium":"https://lain.bgm.tv/r/400/pic/crt/l/4c/b9/31512_prsn_Z57Xv.jpg?r=1551440055"},"name":"島袋美由利","short_summary":"『ゆらぎ荘の幽奈さん』の湯ノ花幽奈役で初のメインキャラクターを担当。\r\n\r\n日本的女性声优，冲绳县出身。大泽事务所所属。\r\n\r\n2017年、『キラキラ☆プリキュアアラモード』でデビュー。2020年、第14回声優アワードで新人女優賞を受賞。","career":["seiyu"],"id":31512,"type":1,"locked":false}],"type":1,"id":160755},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/0c/3e/160756_crt_tT5RM.jpg?r=1720316430","grid":"https://lain.bgm.tv/r/200/pic/crt/l/0c/3e/160756_crt_tT5RM.jpg?r=1720316430","large":"https://lain.bgm.tv/pic/crt/l/0c/3e/160756_crt_tT5RM.jpg?r=1720316430","medium":"https://lain.bgm.tv/r/400/pic/crt/l/0c/3e/160756_crt_tT5RM.jpg?r=1720316430"},"name":"高田","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/4e/a5/23533_prsn_SUZzp.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/4e/a5/23533_prsn_SUZzp.jpg","large":"https://lain.bgm.tv/pic/crt/l/4e/a5/23533_prsn_SUZzp.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/4e/a5/23533_prsn_SUZzp.jpg"},"name":"三浦勝之","short_summary":"日本の男性声優。アトミックモンキー所属。石川県出身。","career":["seiyu"],"id":23533,"type":1,"locked":false}],"type":1,"id":160756},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/98/77/160757_crt_4bNHN.jpg?r=1720316446","grid":"https://lain.bgm.tv/r/200/pic/crt/l/98/77/160757_crt_4bNHN.jpg?r=1720316446","large":"https://lain.bgm.tv/pic/crt/l/98/77/160757_crt_4bNHN.jpg?r=1720316446","medium":"https://lain.bgm.tv/r/400/pic/crt/l/98/77/160757_crt_4bNHN.jpg?r=1720316446"},"name":"下村","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/86/8d/39597_prsn_MvSMl.jpg?r=1600507601","grid":"https://lain.bgm.tv/r/200/pic/crt/l/86/8d/39597_prsn_MvSMl.jpg?r=1600507601","large":"https://lain.bgm.tv/pic/crt/l/86/8d/39597_prsn_MvSMl.jpg?r=1600507601","medium":"https://lain.bgm.tv/r/400/pic/crt/l/86/8d/39597_prsn_MvSMl.jpg?r=1600507601"},"name":"大野智敬","short_summary":"かつてはビットプロモーションに所属。2018年3月9日にビットプロモーションのプロダクション独立より設立されたブライドイデアに移籍。2019年3月31日を以ってブライトイデアを退所し、同年4月1日よりマウスプロモーションに