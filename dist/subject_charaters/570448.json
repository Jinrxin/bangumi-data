c/crt/g/3a/9c/7559_prsn_HpHhl.jpg","large":"https://lain.bgm.tv/pic/crt/l/3a/9c/7559_prsn_HpHhl.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/3a/9c/7559_prsn_HpHhl.jpg"},"name":"山本兼平","short_summary":"日本の男性声優、舞台俳優。旧名ヤマモト ヒロフミ。 東京都出身。EARLY WING所属。","career":["artist","seiyu"],"id":7559,"type":1,"locked":false}],"type":1,"id":208398},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/6d/d6/208399_crt_ws8Pw.jpg","grid":"https://lain.bgm.tv/pic/crt/g/6d/d6/208399_crt_ws8Pw.jpg","large":"https://lain.bgm.tv/pic/crt/l/6d/d6/208399_crt_ws8Pw.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6d/d6/208399_crt_ws8Pw.jpg"},"name":"子爵夫人","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/15/17/3902_seiyu_anidb.jpg","grid":"https://lain.bgm.tv/pic/crt/g/15/17/3902_seiyu_anidb.jpg","large":"https://lain.bgm.tv/pic/crt/l/15/17/3902_seiyu_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/15/17/3902_seiyu_anidb.jpg"},"name":"永島由子","short_summary":"日本の女性声優、ナレーターである。青二プロダクション所属。大阪府出身。愛称はゆっぴー。血液型はO型。夫は声優の上田燿司。\r\n\r\n関西外国語短期大学卒業。青二塾大阪校 8期卒業。\r\n\r\n夫は声優の上田燿司。2008年5月2日に女児出産。","career":["seiyu"],"id":3902,"type":1,"locked":false}],"type":1,"id":208399},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/6e/e9/209061_crt_27pEH.jpg","grid":"https://lain.bgm.tv/pic/crt/g/6e/e9/209061_crt_27pEH.jpg","large":"https://lain.bgm.tv/pic/crt/l/6e/e9/209061_crt_27pEH.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6e/e9/209061_crt_27pEH.jpg"},"name":"白羽","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/a9/6a/64203_prsn_Oq3q8.jpg","grid":"https://lain.bgm.tv/pic/crt/g/a9/6a/64203_prsn_Oq3q8.jpg","large":"https://lain.bgm.tv/pic/crt/l/a9/6a/64203_prsn_Oq3q8.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/a9/6a/64203_prsn_Oq3q8.jpg"},"name":"長岡龍歩","short_summary":"出身地 兵庫県\r\n方言 関西弁\r\n趣味・特技 歌唱、ダンス・アクロバット","career":["seiyu"],"id":64203,"type":1,"locked":false}],"type":1,"id":209061},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/11/e9/209062_crt_JDOO4.jpg","grid":"https://lain.bgm.tv/pic/crt/g/11/e9/209062_crt_JDOO4.jpg","large":"https://lain.bgm.tv/pic/crt/l/11/e9/209062_crt_JDOO4.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/11/e9/209062_crt_JDOO4.jpg"},"name":"鍾呼","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/c9/09/4382_prsn_vvvl9.jpg?r=1705722060","grid":"https://lain.bgm.tv/pic/crt/g/c9/09/4382_prsn_vvvl9.jpg?r=1705722060","large":"https://lain.bgm.tv/pic/crt/l/c9/09/4382_prsn_vvvl9.jpg?r=1705722060","medium":"https://lain.bgm.tv/r/400/pic/crt/l/c9/09/4382_prsn_vvvl9.jpg?r=1705722060"},"name":"井上麻里奈","short_summary":"日本女性声优、歌手。\r\n代表作有《柯塞特的肖像》的柯塞特、《天元突破红莲之眼》的优子、《图书馆战争》的笠原郁等。\r\n\r\n学习院女子中高等科、学习院大学法学院政治系毕业。同业同行柿原彻也是同校大她一届的学长。\r\n小学时从属于演剧部，在合唱部挂名。初中与高中读的都是女校（初高中同校）。\r\n2003年，大学一年级的时候参加索尼音乐SD集团声优试镜会，从2000位应试者之中通过。\r\n2004年5月26日，于新房昭之执导的OVA动画《柯塞特的肖像》为主角柯塞特献声成为出道作。并在同名作品，由梶浦由记企划制作的主题歌“宝石”与插入歌“Ballad”担任主唱。\r\n2007年，于1月播出《月面兔兵器米娜》第一次在电视动画配音主演。同年，获颁“Anime Grand年度”最优秀女性声优奖和“Anican大赏新人奖”第1名。\r\n2007年3月20日，从学习院大学毕业。\r\n2007年10月20日，在第20届东京国际电影节中，放映了麻里奈担任主役野口百南花的OVA动画《少女杀手》，第一次踏上了红地毯。\r\n2007年获得广播节目《范子与大雄的动画大乱斗》里的2007最优秀女性声优奖、并获得了アニカン大奖的新人奖第一名，被评价为实力派声优。\r\n2008年1月1日，因公司从声优市场撤离，离开Voice&Heart事务所，加入现在所属的Sigma Seven。同日，她的部落格也从playlog转到yaplog，名称不变（マリナビ！）。 \r\n2013年5月30日，出版自身第一本连载汇集《井上麻里奈 MariIro》。年12月31日，于第64回NHK红白歌合战轮到音乐组合Linked Horizon献唱自身参演电视动画《进击的巨人》片头主题曲“红莲的弓矢 红白特辑ver.”之际，用声演角色阿尔敏·亚鲁雷特的声音担任节目开场旁白。\r\n2014年8月22日，获颁加拿大温哥华的国际动画祭典“Anime Revolution 2014”“INTERNATIONAL VOICE ACTOR AWARD”。\r\n\r\n井上的母亲当初打算替她取名“まりあ”，但全家和亲戚认为这个读音和日文圣母“玛莉亚”相同、基督教的色彩太过浓厚而强烈反对，最后母亲在不得不妥协之下，改掉一个字就变成如现在的“まりな”（麻里奈）。而在井上她的名字里，“井上”这姓氏是艺名（麻里奈是本名），原因是因为刚出道时经纪人认为这名字感觉很好所以就决定采用了。\r\n有两个同生日的哥哥。\r\n动画电影《图书馆战争 革命之翼》首映会活动当天，主持人就问“剧场动画化决定是听谁说而得知的？”，共演者前野智昭说是从她（麻里奈）打电话通知而得知。除此之外，井上曾受到前辈绪方惠美与多次共同演出的神谷浩史称赞说她是业界中的美人，以及人品不错的评价。还有，后进的诹访彩花对井上也有所憧憬。\r\n对于需要有一位帮后进声优进行指导的团长，井上则选了同事务所前辈吉野裕行当她的导师。这是因为井上在刚出道时，于参演电视动画《牙 -KIBA-》看到吉野帮主角配音时，其演技烙印在她的脑海留下了深刻的印象。并说将来要成为像吉野能将现场气氛变得更加美好，并没有所谓的前辈与后辈之分的演员。因此漫画《境界之轮回》的作者高桥留美子说，井上照顾跟她一起共演的声优的表现，让在录音室现场的高桥看了相当感激。\r\n喜欢的食物有御好烧、文字烧等“面食”，而她也很擅长作这些料理。其它擅长的料理还有炒饭、蛋包饭及酸奶牛肉，为注重饮食的均衡，她尽量都是在家自己做。\r\n兴趣有风景和人物的观赏与绘画素描、料理。特长是裁缝。喜欢的动物是猫。\r\n从小学过的有钢琴、芭蕾舞、游泳、公文式、ESS、书法（初段）。而她的书法是在母亲的教导下准备参加书法检定或书法比赛时学习。并在声优出道后上电台节目时曾经展露书法。\r\n井上说学生时代虽然没有看过动画，但是有看过原作漫画。当中让她看得最入神的漫画是《灌篮高手》，因此她也喜欢篮球。\r\n\r\n井上说会成为声优的理由是，想当可以扮演男性角色的演员。一方面在高中时期（就读女校）参加话剧时，总是扮演男角。但进入大学之后，因为没有饰演男角的机会，因此是在经过一番考虑之后，才会决定要当声优的。还有，前辈绪方惠美是让井上意识到有声优这项职业存在的人。\r\n出道之前，井上原本规划大学1～2年级先打工存钱，3～4年级再上声优学校。但是考虑到了最后，她想知道自己有多少实力而直接参加试镜，结果，在审查的最终阶段中通过。\r\n新人时期，井上在OVA《柯塞特的肖像》突如其来地得到帮女主角配音的机会，所以在录音时总是重来。她说，当时是在斋贺光希温柔的指导之下，不断的吸收与学习当专业声优的知识。\r\n参加游戏《蓝龙》主角修的配音时，因为呼喊的场景太多而导致失声，所以她是在一边去看医生一边完成录音。在录音之前，因为总是有想不开的地方而一脸苦恼，被音响监督告诉她说“尽力而为就可以了” ，所以后来在接受杂志采访时说对扮演少年角色已经有了信心。\r\n2012年3月，曾经参加朋友编剧执笔的舞台剧。近年来经常参加朴璐美主办的演剧和课程及朗读公演。\r\n\r\n音色广阔，从可怜少女到少年角色都能演绎，在同一作品里分饰多角也不是什么罕见的事。\r\n性格很棒，因此经常参加新人的活动，也时常担当电台主持、2007年是“笨手笨脚”、“麻烦女”，2008年的目标是“爱撒娇的孩子”。\r\n初次亮相时，也成为过杂志《哥特体&萝莉塔圣经》的读者模特。自称“超级机器盲”，连阅读使用说明书都不擅长。\r\n有一只宠物猫叫做“ちくたん”、一开始取名叫做“チクワ”（竹轮的假名，一种圆筒状鱼糕），但后来被年幼时的哥哥叫成了“ちくたん”。\r\n母亲是关西人，有时候上电台也会讲关西方言。\r\n与共演《再见、绝望先生》的女声优们结成了“绝望少女会”，并与共演《美型侦探Labyrins》的女生友们结成了“Labyrins女会”以加深交往。\r\n与牧野由依、藤田咲、喜多村英梨、阿澄佳奈、伊藤加奈惠关系很好，同真田麻美关系密切，称呼其为“麻美姐”。\r\n成为声优的理由是因为高中时代（女校）演剧时总是扮演男角，但是进入大学后就不行了，尽管如此还是想扮演男性角色，所以就想成为声优——因为可以扮演男角。\r\n主役TV动画《月面兔兵器米娜》时因为是新人，总是NG。扮演少年角色的《蓝龙》录音时，因为自己心中所想总是不能表现出来，感到很苦恼。据说因为呼喊的场景太多导致失声，一边去看医生，一边录音。录音之前总是有想不开的地方，一脸苦恼，被音响监督告诉“尽力而为就可以了”，后来在杂志采访时说对扮演少年角色已经有信心了。\r\n\r\n擅长画图，因此在自己主演或参演作品《月面兔兵器米娜》、《旋风管家》、《ZEGAPAIN》、《天元突破 红莲螺岩》、《绝望先生》、《南家三姊妹》、《战场女武神》等参加过动画幕后的工作。\r\n在《ZEGAPAIN -ゼーガペイン》ED中，对于主要人设的作画以及对人设的ミナト视点的评语被采用，主管了画稿，由横田耕三上色。\r\n天元突破红莲之眼DVD第一卷的特典采访中挑战了动画作成，也担任了“月面兔兵器米娜”全13回的副标题作画。\r\n曾亲自参与《旋风管家》第一季35-38回的作画。\r\n\r\n逸事\r\n井上在光之美少女系列《Smile 光之美少女！》得到主角绿川直／旋风天使的配音时，她自己相当高兴到流眼泪，并且对想演变身美少女主角的机会有所憧憬。\r\n一方面，以前在《美少女战士》系列帮水手木星配音的篠原惠美，在这部光之美少女饰演另一位女主角青木丽华的母亲。篠原在录制完第16话跟绿川直的对话之后，高兴的说“麻里奈跟我一样是绿色的”，井上回家后高兴地哭了。\r\n井上参加漫画家高桥留美子漫画改编电视动画《境界之轮回》女主角真宫樱的试镜会期间，偶然购入高桥的代表作之一《乱马½》动画版DVD套组，并全程观赏过一次。她说从小能和高桥老师的作品邂逅是一种光荣，即使在试镜会被采用也是一种幸福；还有被拔擢饰演真宫樱的事让自己也吓了一大跳，虽然说有压力，可是也很高兴。\r\n当初，井上说“樱是普通的女孩子，但是她的心神不定。原因是因为我之前在其他作品经常扮演重视感情的角色，所以一开始要表达出樱的感情很困难”，但是她表示“对我来说（真宫樱）这是是一个挑战，随着帮忙配音的进展，我期待自己能表现出樱的感情波动”。\r\n录完之后，高桥非常的感激和肯定井上帮真宫樱配音的表现，并说是她的声音让樱塑造成一个更有活力的角色，还有在保护自己演的角色同时，帮樱展现出可爱的地方和独特的魅力。\r\n除了自己的主演作《境界之轮回》和上面提到的《乱马½》之外，让井上印象最深刻的作品是《相聚一刻》。\r\n动画导演新房昭之说，〈物语〉系列女主角老仓育会请井上担任配音的理由是，他说从小说内容觉得井上的形象可以透过声音，表达出老仓育的魅力。一般角色要由试镜选出，但本次是由新房直接指定担任。\r\n还有，漫画家羽海野千花因为对自身作品《3月的狮子》主角的姐姐、幸田香子的形象与〈物语〉系列老仓育的形象有所重叠。所以在3月的狮子动画化之际，新房才会很希望动画版的幸田香子由井上担任。","career":["artist","seiyu"],"id":4382,"type":1,"locked":false}],"type":1,"id":209062},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/51/e1/209063_crt_5LiU8.jpg","grid":"https://lain.bgm.tv/pic/crt/g/51/e1/209063_crt_5LiU8.jpg","large":"https://lain.bgm.tv/pic/crt/l/51/e1/209063_crt_5LiU8.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/51/e1/209063_crt_5LiU8.jpg"},"name":"依子","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/23/46/31565_prsn_tTZxX.jpg","grid":"https://lain.bgm.tv/pic/crt/g/23/46/31565_prsn_tTZxX.jpg","large":"https://lain.bgm.tv/pic/crt/l/23/46/31565_prsn_tTZxX.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/23/46/31565_prsn_tTZxX.jpg"},"name":"田中貴子","short_summary":"福井県出身の女性声優。マウスプロモーション所属。\r\n\r\n2015年、大阪アニメーションスクール専門学校の声優科 アニメ声優コースを卒業し、マウスプロモーション附属俳優養成所に入所。\r\n2017年4月1日に、マウスプロモーションに入所 。\r\n\r\n趣味・特技は、即興作詞作曲、ピアノ、1人ミュージカル、ジャングル動物の声真似。\r\n自身の性格を一言で表すと「ひもの女」だと語っている。\r\n地球上で一番好きなものには愛、一番嫌いなものにはゴキブリ、日本のホラー映画を挙げている。","career":["seiyu"],"id":31565,"type":1,"locked":false}],"type":1,"id":209063},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/ef/2a/209064_crt_fYnfg.jpg","grid":"https://lain.bgm.tv/pic/crt/g/ef/2a/209064_crt_fYnfg.jpg","large":"https://lain.bgm.tv/pic/crt/l/ef/2a/209064_crt_fYnfg.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/ef/2a/209064_crt_fYnfg.jpg"},"name":"宗玄","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/a0/1d