pic/crt/l/f9/87/207528_crt_u5hY5.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/f9/87/207528_crt_u5hY5.jpg"},"summary":"夏希和波香的母亲。","name":"灰原瑞希","infobox":[{"key":"简体中文名","value":"灰原瑞希"},{"key":"别名","value":[{"k":"日文名","v":"灰原 瑞希"}]},{"key":"性别","value":"女"}],"stat":{"comments":1,"collects":1},"id":207528,"locked":false,"type":1,"nsfw":false},{"birth_mon":3,"gender":"female","birth_day":24,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/99/81/178656_crt_QrfeY.jpg","grid":"https://lain.bgm.tv/pic/crt/g/99/81/178656_crt_QrfeY.jpg","large":"https://lain.bgm.tv/pic/crt/l/99/81/178656_crt_QrfeY.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/99/81/178656_crt_QrfeY.jpg"},"summary":"バスケが大好きな元気で明るいみんなのムードメーカー\r\n\r\n明るく元気なムードメーカー。持ち前の行動力でクラスメイトになった夏希や陽花里たちとすぐに打ち解けていく。趣味はバスケットボールで、美織とともにバスケ部に所属。","name":"佐倉詩","infobox":[{"key":"简体中文名","value":"佐仓诗"},{"key":"别名","value":[{"k":"日文名","v":"佐倉 詩"},{"k":"纯假名","v":"さくら うた"},{"k":"罗马字","v":"Uta Sakura"}]},{"key":"性别","value":"女"},{"key":"生日","value":"3月24日"},{"key":"引用来源","value":[{"v":"https://firecross.jp/feature/haibara"}]}],"stat":{"comments":2,"collects":1},"id":178656,"locked":false,"type":1,"nsfw":false},{"birth_mon":4,"gender":"female","birth_day":3,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/f4/86/200484_crt_A233A.jpg","grid":"https://lain.bgm.tv/pic/crt/g/f4/86/200484_crt_A233A.jpg","large":"https://lain.bgm.tv/pic/crt/l/f4/86/200484_crt_A233A.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/f4/86/200484_crt_A233A.jpg"},"summary":"美织的朋友，轻音社所属。\r\n\r\n軽音部に所属する美織のクラスメイト。ロックを愛し、ギターの腕前は抜群だが、モチベーションの差から部内でバンドを組めず、余りものになっている。","name":"本堂芹香","infobox":[{"key":"简体中文名","value":"本堂芹香"},{"key":"别名","value":[{"k":"纯假名","v":"ほんどう せりか"},{"k":"罗马字","v":"Serika Hondo"}]},{"key":"性别","value":"女"},{"key":"生日","value":"4月3日"},{"key":"引用来源","value":[{"v":"https://haibarakun-anime.com/"}]}],"stat":{"comments":2,"collects":2},"id":200484,"locked":