://lain.bgm.tv/r/200/pic/crt/l/84/84/149148_crt_39xrr.jpg?r=1703430575","large":"https://lain.bgm.tv/pic/crt/l/84/84/149148_crt_39xrr.jpg?r=1703430575","medium":"https://lain.bgm.tv/r/400/pic/crt/l/84/84/149148_crt_39xrr.jpg?r=1703430575"},"summary":"端正な顔立ちに黄金色の瞳を持つ美青年。\r\n水の魔石の生産管理を担う伯爵家・スカルファロット家の四男。\r\n魔物討伐部隊の騎士であり、部隊の中でも最も死に近いとされる\r\n「赤鎧（スカーレットアーマー）」を務めている。\r\n魔剣の話になると少年のような一面を見せる。","name":"ヴォルフレード・スカルファロット","infobox":[{"key":"简体中文名","value":"沃尔夫雷多·斯卡法罗托"},{"key":"别名","value":[]},{"key":"性别","value":"男"},{"key":"引用来源","value":"https://dahliya-anime.com/"}],"stat":{"comments":0,"collects":0},"id":149148,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/ac/7e/154261_crt_OtTz4.jpg?r=1711035268","grid":"https://lain.bgm.tv/r/200/pic/crt/l/ac/7e/154261_crt_OtTz4.jpg?r=1711035268","large":"https://lain.bgm.tv/pic/crt/l/ac/7e/154261_crt_OtTz4.jpg?r=1711035268","medium":"https://lain.bgm.tv/r/400/pic/crt/l/ac/7e/154261_crt_OtTz4.jpg?r=1711035268"},"summary":"ダリヤの幼馴染であり友人。\r\nダリヤが住む緑の塔の門を開けることができる\r\n数少ない人物の1人。\r\n幼少期からの夢を叶え、現在は美容室を営んでいる。\r\n明るく優しい性格で、自分自身の優先度が低い\r\nダリヤのことをいつも心配している。","name":"イルマ・ヌヴォラーリ","infobox":[{"key":"简体中文名","value":"伊尔玛·努沃拉里"},{"key":"别名","value":[]},{"key":"性别","value":"女"}],"stat":{"comments":0,"collects":1},"id":154261,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d1/3e/154262_crt_43Mbe.jpg?r=1711035334","grid":"https://lain.bgm.tv/r/200/pic/crt/l/d1/3e/154262_crt_43Mbe.jpg?r=1711035334","large":"https://lain.bgm.tv/pic/crt/l/d1/3e/154262_crt_43Mbe.jpg?r=1711035334","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d1/3e/154262_crt_43Mbe.jpg?r=1711035334"},"summary":"イルマの夫で運送ギルド員。妻のイルマを愛しており、その友人であるダリヤのことも気遣う。\r\nダリヤの引っ越しの際には、\r\n運送ギルド員として率先して手伝う。\r\nダリヤの商会設立について\r\n背中を押した一人でもある。","name":"マルチェラ・ヌヴォラーリ","infobox":[{"key":"简体中文名","value":"马塞拉·努沃拉里"},{"key":"别名","value":[]},{"key":"性别","value":"男"}],"stat":{"comments":0,"collects":0},"id":154262,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/77/b1/149147_crt_iwkXN.jpg?r=1703430473","grid":"https://lain.bgm.tv/r/200/pic/crt/l/77/b1/149147_crt_iwkXN.jpg?r=1703430473","large":"https://lain.bgm.tv/pic/crt/l/77/b1/149147_crt_iwkXN.jpg?r=1703430473","medium":"https://lain.bgm.tv/r/400/pic/crt/l/77/b1/149147_crt_iwkXN.jpg?r=1703430473"},"summary":"駆け出しの魔導具師。\r\n過労により命を落とした前世の後悔を繰り返さないため、\r\nそして人々の生活を豊かにする、\r\n父・カルロのような魔導具師になるため奮闘中。\r\n魔導具づくりに夢中になると無茶をしてしまうこともしばしば。\r\n美味しいお酒と料理が好き。","name":"ダリヤ・ロセッティ","infobox":[{"key":"简体中文名","value":"妲莉亚·罗塞蒂"},{"key":"别名","value":[]},{"key":"性别","value":"女"},{"key":"引用来源","value":"https://dahliya-anime.com/"}],"stat":{"comments":0,"collects":2},"id":149147,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/51/39/154266_crt_clcaK.jpg?r=1711035664","grid":"https://lain.bgm.tv/r/200/pic/crt/l/51/39/154266_crt_clcaK.jpg?r=1711035664","large":"https://lain.bgm.tv/pic/crt/l/51/39/154266_crt_clcaK.jpg?r=1711035664","medium":"https://lain.bgm.tv/r/400/pic/crt/l/51/39/154266_crt_clcaK.jpg?r=1711035664"},"summary":"ダリヤの魔導具師としての兄弟子。\r\nオルランド商会の次男。\r\n商家に生まれながらも魔導具師になった努力家。\r\nダリヤとロセッティの名前を守るため、\r\nダリヤとの婚約の話を承諾する。","name":"トビアス・オルランド","infobox":[{"key":"简体中文名","value":"托比亚斯·奥兰多"},{"key":"别名","value":[]},{"key":"性别","value":"男"}],"stat":{"comments":0,"collects":0},"id":154266,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/8e/04/159562_crt_Fc0O0.jpg?r=1718375720","grid":"https://lain.bgm.tv/r/200/pic/crt/l/8e/04/159562_crt_Fc0O0.jpg?r=1718375720","large":"https://lain.bgm.tv/pic/crt/l/8e/04/159562_crt_Fc0O0.jpg?r=1718375720","medium":"https://lain.bgm.tv/r/400/pic/crt/l/8e/04/159562_crt_Fc0O0.jpg?r=1718375720"},"summary":"国から名誉男爵の位を与えられた\r\n有能な魔導具師であるダリヤの父。\r\nダリヤの魔導具師としての素質を見抜き、溺愛しながらも、魔導具師としての成長をさりげなく促す一面も。\r\n酒好きでいつも飲みすぎてはダリヤに怒られている。\r\nオルランド商会商会長のテオドーロとは親友。","name":"カルロ・ロセッティ","infobox":[{"key":"简体中文名","value":"卡洛·罗塞蒂"},{"key":"别名","value":[]},{"key":"性别","value":"男"}],"stat":{"comments":0,"collects":0},"id":159562,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/6f/8c/154265_crt_BOf8J.jpg?r=1711035616","grid":"https://lain.bgm.tv/r/200/pic/crt/l/6f/8c/154265_crt_BOf8J.jpg?r=1711035616","large":"https://lain.bgm.tv/pic/crt/l/6f/8c/154265_crt_BOf8J.jpg?r=1711035616","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6f/8c/154265_crt_BOf8J.jpg?r=1711035616"},"summary":"商業ギルドの副ギルド長。\r\n夫はギルド長のレオーネ・ジェッダ子爵。\r\n商業ギルド職員として、そして一人の人間としても、\r\nダリヤの成長を見守り、サポートする。\r\nダリヤの父・カルロとも昔から親交がある。","name":"ガブリエラ・ジェッダ","infobox":[{"key":"简体中文名","value":"加布里埃拉·吉达"},{"key":"别名","value":[]},{"key":"性别","value":"女"}],"stat":{"comments":0,"collects":0},"id":154265,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/9e/5c/154263_crt_JwANS.jpg?r=1711035401","grid":"https://lain.bgm.tv/r/200/pic/crt/l/9e/5c/154263_crt_JwANS.jpg?r=1711035401","large":"https://lain.bgm.tv/pic/crt/l/9e/5c/154263_crt_JwANS.jpg?r=1711035401","medium":"https://lain.bgm.tv/r/400/pic/crt/l/9e/5c/154263_crt_JwANS.jpg?r=1711035401"},"summary":"ダリヤの友人の服飾師。\r\nダリヤの魔導具制作に欠かせない職人の一人。\r\n家族で営むファーノ工房で働いている。\r\n明朗闊達な性格で、物事を嫌味なくはっきりと言う。\r\nいつか自分の工房を持つことと、素敵な服で王都を\r\n埋め尽くすことが夢。","name":"ルチア・ファーノ","infobox":[{"key":"简体中文名","value":"露西娅·弗诺"},{"key":"别名","value":[]},{"key":"性别","value":"女"}],"stat":{"comments":0,"collects":1},"id":154263,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/24/4c/154264_crt_Rz0tn.jpg?r=1711035515","grid":"https://lain.bgm.tv/r/200/pic/crt/l/24/4c/154264_crt_Rz0tn.jpg?r=1711035515","large":"https://lain.bgm.tv/pic/crt/l/24/4c/154264_crt_Rz0tn.jpg?r=1711035515","medium":"https://lain.bgm.tv/r/400/pic/crt/l/24/4c/154264_crt_Rz0tn.jpg?r=1711035515"},"summary":"商業ギルドの契約書管理担当。\r\nダリヤが開発した魔導具登録などの手続きに立ち会う。魔導具師としてのダリヤの可能性に期待しており、\r\n商会設立に一役買う事に。","name":"イヴァーノ・バドエル","infobox":[{"key":"简体中文名","value":"伊万诺·巴多尔"},{"key":"别名","value":[]},{"key":"性别","value":"男"}],"stat":{"comments":0,"collects":0},"id":154264,"locked":false,"type":1,"nsfw":false}]}