e":"https://lain.bgm.tv/pic/crt/l/c3/d0/12484_prsn_U4Ug4.jpg?r=1547646904","medium":"https://lain.bgm.tv/r/400/pic/crt/l/c3/d0/12484_prsn_U4Ug4.jpg?r=1547646904"},"name":"松井恵理子","short_summary":"松井 恵理子（まつい えりこ、1989年3月8日 - ）は、日本の女性声優。愛知県出身。アイアムエージェンシー所属。身長160cm。血液型はB型。\r\n\r\nアニメ、ドラマCDなど、主に声の仕事で活躍。\r\n『まおゆう魔王勇者』のニコニコ生放送『なお☆えりの『まおゆう』盛り上げた〜い！』などで『エイリー』を愛称に挙げており、実際に使われていたが、『未確認で進行形』のニコ生『TVアニメ 未確認で進行形 制作発表 〜番組内容は確認しておきます〜』の第1回で三峰真白役の吉田有里によって名付けられた『カッター』が視聴者アンケートで1位を取ってしまい、選択肢を2つ増やした上で再投票したが、それでも1位が揺るがず、愛称として決定した。ちなみに、エイリー→鋭利→鋭利な刃物→カッター、という発想である。\r\n特技はイラストで、上記ニコ生でもその上手さが発揮されていた。","career":["artist","seiyu"],"id":12484,"type":1,"locked":false}],"type":1,"id":153589},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/7f/22/155321_crt_HfgRs.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/7f/22/155321_crt_HfgRs.jpg","large":"https://lain.bgm.tv/pic/crt/l/7f/22/155321_crt_HfgRs.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/7f/22/155321_crt_HfgRs.jpg"},"name":"リッチ","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d6/ed/4920_prsn_7079X.jpg?r=1510472626","grid":"https://lain.bgm.tv/r/200/pic/crt/l/d6/ed/4920_prsn_7079X.jpg?r=1510472626","large":"https://lain.bgm.tv/pic/crt/l/d6/ed/4920_prsn_7079X.jpg?r=1510472626","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d6/ed/4920_prsn_7079X.jpg?r=1510472626"},"name":"上田燿司","short_summary":"上田 燿司（うえだ ようじ、1971年8月7日 – ）は、日本の声優。アミュレート所属。\r\n兵庫県神戸市垂水区出身。旧名：上田陽司（読みは同じ）、2008年4月1日に改名した。妻は声優の永島由子で現在1児の父。\r\n同じ声優で名前が似ている上田祐司（現・うえだゆうじ）と間違えられることがある。","career":["artist","seiyu"],"id":4920,"type":1,"locked":false}],"type":1,"id":155321},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/49/a8/156133_crt_3l7P4.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/49/a8/156133_crt_3l7P4.jpg","large":"https://lain.bgm.tv/pic/crt/l/49/a8/156133_crt_3l7P4.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/49/a8/156133_crt_3l7P4.jpg"},"name":"ベアウルフ","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/