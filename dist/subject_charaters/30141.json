75_seiyu_anidb.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/60/dc/4475_seiyu_anidb.jpg","large":"https://lain.bgm.tv/pic/crt/l/60/dc/4475_seiyu_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/60/dc/4475_seiyu_anidb.jpg"},"name":"保村真","short_summary":"与吉野裕行非常关系好。平时话很少（本人说）。\r\n保村真出道后一直没有扮演过重要的角色，2006年在《甜蜜声优》中担任男主角松丸文彦，保村真本身应该是挺能搞笑的人，与松丸文彦的沉闷大相径庭主要作品","career":["seiyu"],"id":4475,"type":1,"locked":false}],"type":1,"id":10009}],"detail":[{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/69/f2/3349_crt_anidb.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/69/f2/3349_crt_anidb.jpg","large":"https://lain.bgm.tv/pic/crt/l/69/f2/3349_crt_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/69/f2/3349_crt_anidb.jpg"},"summary":"","name":"ジョー・ギブソン","infobox":[{"key":"身高","value":"198"},{"key":"体重","value":"95"},{"key":"性别","value":"男"},{"key":"别名","value":[{"k":"日文名","v":"ジョー・ギブソン"},{"k":"罗马字","v":"Joe Gibson"}]},{"key":"引用来源","value":"anidb.net"}],"stat":{"comments":0,"collects":0},"id":3349,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/48/3d/10009_crt_anidb.jpg?r=1427918625","grid":"https://lain.bgm.tv/r/200/pic/crt/l/48/3d/10009_crt_anidb.jpg?r=1427918625","large":"https://lain.bgm.tv/pic/crt/l/48/3d/10009_crt_anidb.jpg?r=1427918625","medium":"https://lain.bgm.tv/r/400/pic/crt/l/48/3d/10009_crt_anidb.jpg?r=1427918625"},"summary":"ＭＡＪＯＲ（メジャー）：\r\n眉村健（海堂高校時代の吾郎の最大のライバル投手。ルーキーとして唯一、最初からＷ杯日本代表に選ばれた）\r\n\r\nゲーム「実況パワフルプロ野球」：\r\n所属チーム ：海堂学園高校\r\nジャイロボールと多彩な変化球を操る右腕。打撃も一流。その存在感は、試合の流れすら変える。","name":"眉村健","infobox":[{"key":"简体中文名","value":"眉村健"},{"key":"别名","value":[{"k":"日文名","v":"眉村健"},{"k":"纯假名","v":"まゆむら けん"},{"k":"罗马字","v":"Mayumura Ken"}]},{"key":"性别","value":"男"},{"key":"引用来源","value":[{"v":"anidb.net"},{"k":"原作漫画","v":"https://shogaku