0/pic/crt/l/ed/db/197580_crt_Wuug8.jpg","grid":"https://lain.bgm.tv/pic/crt/g/ed/db/197580_crt_Wuug8.jpg","large":"https://lain.bgm.tv/pic/crt/l/ed/db/197580_crt_Wuug8.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/ed/db/197580_crt_Wuug8.jpg"},"name":"エセル・グレイル","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/33/a6/71489_prsn_00LbK.jpg","grid":"https://lain.bgm.tv/pic/crt/g/33/a6/71489_prsn_00LbK.jpg","large":"https://lain.bgm.tv/pic/crt/l/33/a6/71489_prsn_00LbK.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/33/a6/71489_prsn_00LbK.jpg"},"name":"西垣俊作","short_summary":"日本の男性声優。リマックス所属。東京都出身。妻は声優の坂田有希。\r\n\r\n趣味：ダム巡り、ツーリング\r\n資格：中型自動車免許,大型自動二輪免許,剣道初段\r\n特技：盲牌、バドミントン","career":["seiyu"],"id":71489,"type":1,"locked":false}],"type":1,"id":197580},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/b3/c3/197581_crt_qYi10.jpg","grid":"https://lain.bgm.tv/pic/crt/g/b3/c3/197581_crt_qYi10.jpg","large":"https://lain.bgm.tv/pic/crt/l/b3/c3/197581_crt_qYi10.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/b3/c3/197581_crt_qYi10.jpg"},"name":"ブレンダ","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/88/83/49243_prsn_w1I0S.jpg?r=1708511750","grid":"https://lain.bgm.tv/pic/crt/g/88/83/49243_prsn_w1I0S.jpg?r=1708511750","large":"https://lain.bgm.tv/pic/crt/l/88/83/49243_prsn_w1I0S.jpg?r=1708511750","medium":"https://lain.bgm.tv/r/400/pic/crt/l/88/83/49243_prsn_w1I0S.jpg?r=1708511750"},"name":"平塚紗依","short_summary":"2022年にテレビアニメ『僕とロボコ』のメイコ役でデビュー。2024年に『ひみつのアイプリ』の星川みつき役でダブル主人公の1人として主演する事になった。","career":["seiyu"],"id":49243,"type":1,"locked":false}],"type":1,"id":197581},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/59/c2/197582_crt_qfaaA.jpg","grid":"https://lain.bgm.tv/pic/crt/g/59/c2/197582_crt_qfaaA.jpg","large":"https://lain.bgm.tv/pic/crt/l/59/c2/197582_crt_qfaaA.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/59/c2/197582_crt_qfaaA.jpg"},"name":"ウェイン","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/aa/41/41969_prsn_8kDI7.jpg?r=1623239803","grid":"https://lain.bgm.tv/pic/crt/g/aa/41/41969_prsn_8kDI7.jpg?r=1623239803","large":"https://lain.bgm.tv/pic/crt/l/aa/41/41969_prsn_8kDI7.jpg?r=1623239803","medium":"https://lain.bgm.tv/r/400/pic/crt/l/aa/41/41969_prsn_8kDI7.jpg?r=1623239803"},"name":"宮﨑雅也","short_summary":"スターダストプロモーション 声優部 所属\r\n\r\n出身地　大阪府\r\n趣味　音楽鑑賞\r\n特技　軟式テニス、関西弁","career":["seiyu"],"id":41969,"type":1,"locked":false}],"type":1,"id":197582},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/9f/56/198513_crt_IY5nM.jpg","grid":"https://lain.bgm.tv/pic/crt/g/9f/56/198513_crt_IY5nM.jpg","large":"https://lain.bgm.tv/pic/crt/l/9f/56/198513_crt_IY5nM.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/9f/56/198513_crt_IY5nM.jpg"},"name":"アイシャ・ハクスリー","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/1b/c3/4398_prsn_XMW01.jpg?r=1730732992","grid":"https://lain.bgm.tv/pic/crt/g/1b/c3/4398_prsn_XMW01.jpg?r=1730732992","large":"https://lain.bgm.tv/pic/crt/l/1b/c3/4398_prsn_XMW01.jpg?r=1730732992","medium":"https://lain.bgm.tv/r/400/pic/crt/l/1b/c3/4398_prsn_XMW01.jpg?r=1730732992"},"name":"小林ゆう","short_summary":"配音范围，从少年至美少女，亦或是活力充沛的角色，都没有问题。\r\n当声优以前是个十分活跃的杂志模特，这是一个与众不同的经历。可能因为这样，身高在女声优界中是很高的168cm，只是比170cm以上的本田贵子、汤屋敦子、葛城七穗矮一点。\r\n母亲是插花师傅。亦可能因为这样，对任何事也十分谦虚有礼，众所周知她很平易近人。\r\n对同年、甚至比自己年轻的同事经常也会在名字后加“～さん(先生/小姐)”，虽然如此，但却把比自己大一年的中原麻衣唤做“まいたん”\r\n在广播中，几乎每次也会把手或头碰到麦克风，每次也很热衷于节目中的游戏，无意识地发出喘气声。\r\n喜欢料理。自己有糠床(由米糠和盐混制而成，是做 糠渍け 的主要原料)，用来做糠渍け(一种用米糠拌盐腌的和式小菜)。\r\n为了练习配音和唱歌的技巧，经常独自一人在卡啦ok流连，连卡啦ok的店员们也认得出她的样貌。某日和声优朋友一起唱卡啦ok时，还被店员说了“今天和朋友们一起来真是太好了”。\r\n在决定“魔法老师”将会有演出时开始学习剑道，但现在好像已经放弃了。\r\n因广播节目中游戏的惩罚，曾穿着“魔法老师”中麻帆良学园的校服在新宿站坐地下铁，沿湘南新宿线坐到高崎线深谷站，并在深谷站前唱了“聖なる空の下で”。\r\n看了“魔法老师”漫画第114话“みんながいるからボクがいる”涅吉和刹那对战后，好像有点悲伤地向作者赤松健说“请让刹那胜利吧…”。\r\n2006年5月8日的网上广播“麻帆良学園中等部2-A・ヒミツの放課後 Part2”，为了取材而和佐藤利奈一起来到录音室的赤松健，给小林优体验了一下当助手的感觉而让她在“魔法先生ネギま！”第136话“チーム・ネギ坊主”(单行本第15卷的109页，中日单行本相同)的第1页第7格写下了“もぞもぞ…”和“うじうじ”。\r\n2006年6月20日，名为“White Wing”的fans club成立了。\r\n喜欢的动物是兔子，而且曾经饲养，名叫Nono（ノノ）。另外似乎很满意看到自己配音的刹那在漫画中戴上兔耳cosplay。\r\n2007年2月4日，Saint October的op“Wheel of fortune”pv拍摄完毕后，2月5日凌晨0:00，一众工作人员以及一起拍摄的片冈あづさ，福井裕佳梨为她庆祝生日，给了她一个惊喜。就在把蜡烛吹熄后，一如以往为表感谢而鞠躬的她，碰到了工作人员手拿的蛋糕，把头上戴着的帽子弄脏了，惹得大家都笑了。\r\n2008年获得声优奖女优部门新人赏。\r\n2009年在Animelo Summer Live 2009 与其他“绝望少女达”（野中蓝、新谷良子、小林优、泽城美雪）人员及大槻ケンヂ一起演出动画“绝望老师”的相关曲“人として轴がぶれている”、“空想ルンバ”和“林檎もぎれビーム! ”。其中小林优与泽城美雪在表演时同时进入“疯狂状态”，十分卖力地演出。事后根据小林本人说，唱完三首歌回到了后台之后就晕倒了，其后发现颈亦受伤了，以致9月份的个人首唱会都不能作强烈的颈部运动。\r\n同年冬天与RYO组成2人乐团“Crush Tears”，出现第一首曲“闪光の瞬き”。于2010年2月17日发表此曲。\r\n2010年Crush Tears组合增加2人，现变成四人乐团，新曲为动画“爆丸”相关曲“Communication Breakdown”此曲发售日期为7月7日。\r\n绘画十分的不济，画什么也会变成自己独创的东西，因而被称为“画伯”（大画家）。\r\n2006年6月9日发布在网上广播所画的画（魔法先生ネギま！的登场人物源静奈）时，还因为画作有某方面的危险而被工作人员修正了。\r\n赤松健的日记中对其他声优会在名字后加“さん”（先生/小姐），而小林却是“画伯”。\r\n\r\n2017年12月29日，在个人Twitter上宣布结婚消息。","career":["artist","seiyu"],"id":4398,"type":1,"locked":false}],"type":1,"id":198513},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/45/cf/198514_crt_L7bQt.jpg","grid":"https://lain.bgm.tv/pic/crt/g/45/cf/198514_crt_L7bQt.jpg","large":"https://lain.bgm.tv/pic/crt/l/45/cf/198514_crt_L7bQt.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/45/cf/198514_crt_L7bQt.jpg"},"name":"エミリア・ゴードウィン","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/b5/91/5192_prsn_Y6vwF.jpg?r=1595854480","grid":"https://lain.bgm.tv/pic/crt/g/b5/91/5192_prsn_Y6vwF.jpg?r=1595854480","large":"https://lain.bgm.tv/pic/crt/l/b5/91/5192_prsn_Y6vwF.jpg?r=1595854480","medium":"https://lain.bgm.tv/r/400/pic/crt/l/b5/91/5192_prsn_Y6vwF.jpg?r=1595854480"},"name":"原紗友里","short_summary":"参加第2回的81竞试，获得优秀奖。2009年10月开始加入81 Produce。\r\n    2010年7月30日与同事务所的阿澄佳奈、片冈梓组成声优团体“LISP”。","career":["seiyu"],"id":5192,"type":1,"locked":false}],"type":1,"id":198514},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e4/db/198516_crt_sVfvk.jpg","grid":"https://lain.bgm.tv/pic/crt/g/e4/db/198516_crt_sVfvk.jpg","la