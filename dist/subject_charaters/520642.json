c/crt/g/32/3e/56925_prsn_chsHw.jpg","large":"https://lain.bgm.tv/pic/crt/l/32/3e/56925_prsn_chsHw.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/32/3e/56925_prsn_chsHw.jpg"},"name":"漆山ゆうき","short_summary":"日本の女性声優。山形県出身。賢プロダクション所属。\r\n特技・趣味：管理栄養士免許、細胞の培養、イラスト、山形弁、社交ダンス","career":["seiyu"],"id":56925,"type":1,"locked":false}],"type":1,"id":198518},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d9/30/198519_crt_mrm5m.jpg","grid":"https://lain.bgm.tv/pic/crt/g/d9/30/198519_crt_mrm5m.jpg","large":"https://lain.bgm.tv/pic/crt/l/d9/30/198519_crt_mrm5m.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d9/30/198519_crt_mrm5m.jpg"},"name":"ジョージ","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/75/93/52711_prsn_V3SYV.jpg?r=1701261455","grid":"https://lain.bgm.tv/pic/crt/g/75/93/52711_prsn_V3SYV.jpg?r=1701261455","large":"https://lain.bgm.tv/pic/crt/l/75/93/52711_prsn_V3SYV.jpg?r=1701261455","medium":"https://lain.bgm.tv/r/400/pic/crt/l/75/93/52711_prsn_V3SYV.jpg?r=1701261455"},"name":"結川あさき","short_summary":"出身地：東京都\r\n趣味・スポーツ：音楽、ゲーム\r\n特技：フットサル\r\n資格：日本漢字能力検定準1級\r\n芸歴：日本ナレーション演技研究所","career":["seiyu"],"id":52711,"type":1,"locked":false}],"type":1,"id":198519},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/94/21/200446_crt_PsN2B.jpg","grid":"https://lain.bgm.tv/pic/crt/g/94/21/200446_crt_PsN2B.jpg","large":"https://lain.bgm.tv/pic/crt/l/94/21/200446_crt_PsN2B.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/94/21/200446_crt_PsN2B.jpg"},"name":"デボラ・ダルキアン","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/01/33/4249_prsn_l0jSI.jpg?r=1725291268","grid":"https://lain.bgm.tv/pic/crt/g/01/33/4249_prsn_l0jSI.jpg?r=1725291268","large":"https://lain.bgm.tv/pic/crt/l/01/33/4249_prsn_l0jSI.jpg?r=1725291268","medium":"https://lain.bgm.tv/r/400/pic/crt/l/01/33/4249_prsn_l0jSI.jpg?r=1725291268"},"name":"斎藤千和","short_summary":"高中三年级时的7月，日本播音演技研究所入学。次年1月加入I'm Enterprise旗下声优养成机构剧团ヴォアレーヴ。\r\n2001年，初次出演动画《可可露图书馆》的主人公可可露，表现优异，完全表现出主人公的可爱之处，但随后的一年半因学业问题，完全不接任何动画配音的工作。\r\n2002年，与植田佳奈、森永理科以中原麻衣结成声优组合“みっくすJUICE”，随后以组合名义参与CD发行和现场公演等音乐活动以及电视和电台广播节目的演出。\r\n2003年，日本播音演技研究所毕业。声优组合“みっくすJUICE”解散。\r\n2011年10月获得《Newtype×マチ★アソビ 动画奖2011》助演女声优赏，所出演角色晓美焰获女性角色赏。\r\n2013年7月29日，在事务所官方网站上宣布了结婚的消息 。\r\n2015年1月，第一个孩子（女儿）诞生。同年10月1日在事务所官网发布了这则消息。\r\n\r\n斋藤千和与声优结缘原因，拜托母亲出外购买看惯的时装杂志《ViVi》时，母亲不小心买错了陈列台上《ViVi》底下的一本声优杂志，令千和对声优开始产生兴趣，从此走上了声优之路。\r\n萌和腹黑（注：毒舌）萝莉系为代表角色，以深厚的配音实力、多变的声线，得到更多人关注。出道以来，为人十分低调，一直踏实的做好自己的本职工作。\r\n家中在家乡开蛋糕店，家族成员共五人，生活融洽，2006年后斋藤千和独自留京租屋工作，仍经常与母亲手机通讯。\r\n兴趣爱好的看电影以及打篮球。\r\n中学时隶属排球部，学业优秀，国语和英语曾在中学全国模拟时获得前10位（但是她说是瞎蒙的），选择高中时以某高中可爱的校服和其外国游学课程为由入学。\r\n高中修学旅行，与同学畅游西班牙途中，同伴的手袋遭劫匪抢走，斋藤千和旋即追上并击败歹徒 。\r\n千和与声优结缘可谓十分戏剧。话说一日，千和拜托母亲出外购买看惯的时装杂志「ViVi」时，母亲顺手买错了陈列台上「ViVi」底下的一本声优杂志，令千和对声优产生兴趣，从此便走上了声优之路。\r\n经常使用的昵称是“ちわ（千和）”，本人则不喜欢“こんにちわちわ”这个昵称。\r\n2002年与同事务所所属同年的声优森永理科、植田佳奈、中原麻衣结成声优团体《综合果汁（みっくすJUICE）》。该团体参与CD发行和live 公演等音乐活动、电视和电台广播节目的演出，而且，在动画《妄想科学美少女》亦有演出。团体于2003年解散。\r\n2003年，出演动画《最终流放》的女主角拉维·黑特，表示通过出演这个角色，使自己第一次深入思考，世界观有了很大的改变。同年的《妄想科学美少女》的秋茂菖蒲和《R.O.D -THE TV-》的阿妮塔·京确立了千和在萌系角色的地位。\r\n《月咏-MOON PHASE-》中的叶月和《不可思议的教室》的宫本蕾贝卡两个角色展现了其萌和腹黑这双重性格同时并存的高超演技以外，透过对白中微带抽泣声，带动了观众的感情，令千和成为当时年青高演技派女声优代表之一。\r\n首个电台广播是oice Crew，与桑谷夏子担任第九代（2001年10月7日 － 2002年9月29日）的共同主持。同时，两人结成组成组合“coopee”，在全国多个地方表演。为了回复FANS的来信，当时仍是学生的斋藤千和唯有乘学校午休时间在课室对每封信亲笔回覆。\r\n与歌手中野爱子感情亲密，斋藤千和在2011年其30岁生日前一天，由于发生东日本大地震造成交通堵塞无法回家，就跑到了中野家借宿了一晚。\r\n与新房昭之有过多次合作，《魔法少女小圆》、《月咏-MOON PHASE-》、《化物语》、《不可思议的教室》以及《吸血鬼同盟》的监督都是新房昭之，被粉丝们戏称“新房御用声优”。\r\n因为常常在录影现场吃香蕉，所以被其他人称作“香蕉人”。\r\n能登麻美子曾经对她说“如果到30岁都还是单身的话，就和我结婚让我照顾你吧。”曾以“想让能登幸福”为名，要把弟弟介绍给能登麻美子。","career":["artist","seiyu"],"id":4249,"type":1,"locked":false}],"type":1,"id":200446},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e5/51/200447_crt_Zp9HZ.jpg","grid":"https://lain.bgm.tv/pic/crt/g/e5/51/200447_crt_Zp9HZ.jpg","large":"https://lain.bgm.tv/pic/crt/l/e5/51/200447_crt_Zp9HZ.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e5/51/200447_crt_Zp9HZ.jpg"},"name":"エルンスト・アデルバイド","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/b6/c6/4658_prsn_aS1Y8.jpg","grid":"https://lain.bgm.tv/pic/crt/g/b6/c6/4658_prsn_aS1Y8.jpg","large":"https://lain.bgm.tv/pic/crt/l/b6/c6/4658_prsn_aS1Y8.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/b6/c6/4658_prsn_aS1Y8.jpg"},"name":"東地宏樹","short_summary":"毕业于日本大学艺术学部戏剧学科，起初主要参加舞台剧演出。刚开始做配音演员工作的时候，主要是录制旁白。\r\n\r\n第一次从事外语电影配音工作，是为港日合拍电影《安娜马德莲娜》中金城武扮演的男主角陈家富配音，为这个角色寻找配音演员的经纪人很喜欢东地的声音，向他发出了邀请。\r\n\r\n正式进入配音演员行业的契机，是NTV电视台《星期五巡演》栏目播出的《黑衣人》配音版。电视台来到事务所遴选威尔史密斯的配音演员时，东地宏树自认是威尔的影迷，因此报名参选并最终合格。此后，东地宏树主要致力于外语片配音工作，除了威尔史密斯和金城武之外，还为克里斯蒂安贝尔、萨姆沃辛顿、韩星朴新阳等人配音。特别是通过为美剧《越狱》的男主角Michael配音提高了知名度。\r\n\r\n在动画、广播剧CD、游戏等领域也十分活跃。动画中，多为成年男性、青年到较大龄男性配音。在游戏上，参加了Tri-Ace公司的一大半作品。Level-5公司的作品也出演了很多。此外，东地宏树担任了《神秘海域》系列游戏全部日文版的男主角配音。\r\n\r\n2012年，获得FAMI通大奖男性配音演员奖。","career":["seiyu"],"id":4658,"type":1,"locked":false}],"type":1,"id":200447},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/5c/00/200449_crt_R64MP.jpg","grid":"https://lain.bgm.tv/pic/crt/g/5c/00/200449_crt_R64MP.jpg","large":"https://lain.bgm.tv/pic/crt/l/5c/00/200449_crt_R64MP.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/5c/00/200449_crt_R64MP.jpg"},"name":"カイル","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d6/95/24755_prsn_VWqEP.jpg","grid":"https://lain.bgm.tv/pic/crt/g/d6/95/24755_prsn_VWqEP.jpg","large":"https://lain.bgm.tv/pic/crt/l/d6/95/24755_prsn_VWqEP.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d6/95/24755_prsn_VWqEP.jpg"},"name":"駒田航","short_summary":"81produce所属\r\n\r\n出身地：ドイツ連邦共和国\r\n(出生地：神奈川県)\r\n趣味・特技：英会話、カメラ\r\n映画鑑賞、ダーツ、バレーボール","career":["seiyu"],"id":24755,"type":1,"locked":false}],"type":1,"id":200449},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/00/4a/200450_crt_Lc6AV.jpg","grid":"https://lain.bgm.tv/pic/crt/g/00/4a/200450_crt_Lc6AV.jpg","large":"https://lain.bgm.tv/pic/crt/l/00/4a/200450_crt_Lc6AV.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/00/4a/200450_crt_Lc6AV.jpg"},"name":"ゲオルグ・ガイナ","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/75/9c/31361_prsn_GOy7L.jpg","grid":"https://lain.bgm.tv/pic/crt/g/75/9c/31361_prsn_GOy7L.jpg","large":"https://lain.bgm.tv/pic/crt/l/75/9c/31361_prsn_GOy7L.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/75/9c/31361_prsn_GOy7L.jpg"},"name":"新祐樹","short_summary":"新 祐樹（しん ゆうき、1994年3月6日 - ）は、日本の男性声優。\r\n賢プロダクション所属。神奈川県出身。\r\n特技、趣味は料理、フットサル、サバイバルゲーム、テレビゲーム。","career":["seiyu"],"id":31361,"type":1,"locked":false}],"type":1,"id":200450}],"detail":[{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e4/db/198516_crt_sVfvk.jpg","grid":"https://lain.bgm.tv/pic/crt/g/e4/db/198516_crt_sVfvk.jpg","large":"https://lain.bgm.tv/pic/crt/l/e4/db/198516_crt_sVfvk.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e4/db/198516_crt_sVfvk.jpg"},"summary":"","name":"マーゴット・テューダー","infobox":[{"key":"简体中文名","value":"玛格·都铎"},{"key":"别名","value":[{"k":"英文名","v":"Margot Tudor"}]},{"key":"性别","value":"女"}],"stat":{"comments":0,"collects":0},"id":198516,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/81/e5/198517_crt_A2ZhA.jpg","grid":"https://lain.bgm.tv/pic/crt/g/81/e5/198517_crt_A2ZhA.jpg","large":"https://lain.bgm.tv/pic/crt/l/81/e5/198517_crt_A2ZhA.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/81/e5/198517_crt_A2ZhA.jpg"},"summary":"","name":"キアラ・グラフトン","infobox":[{"key":"别名","value":[]},{"key":"性别","value":"女"}],"stat":{"comments":0,"collects":0},"id":198517,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d5/76/192210_crt_3nLY4.jpg","grid":"https://lain.bgm.tv/pic/crt/g/d5/76/1922