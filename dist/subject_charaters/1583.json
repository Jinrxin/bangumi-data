er":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/76/6e/587_zoF4q.jpg","grid":"https://lain.bgm.tv/pic/crt/g/76/6e/587_zoF4q.jpg","large":"https://lain.bgm.tv/pic/crt/l/76/6e/587_zoF4q.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/76/6e/587_zoF4q.jpg"},"summary":"","name":"天野あい","infobox":[{"key":"简体中文名","value":"天野爱"},{"key":"别名","value":[{"k":"纯假名","v":"あまの　あい"},{"k":"罗马字","v":"amano ai"}]},{"key":"性别","value":"女"},{"key":"声优","value":"林原めぐみ"}],"stat":{"comments":2,"collects":18},"id":587,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/74/03/496_crt_gbH7O.jpg","grid":"https://lain.bgm.tv/pic/crt/g/74/03/496_crt_gbH7O.jpg","large":"https://lain.bgm.tv/pic/crt/l/74/03/496_crt_gbH7O.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/74/03/496_crt_gbH7O.jpg"},"summary":"","name":"新舞貴志","infobox":[{"key":"简体中文名","value":"新舞贵志"},{"key":"别名","value":[]},{"key":"性别","value":"男"}],"stat":{"comments":0,"collects":0},"id":496,"locked":false,"type":1,"nsfw":false}]}