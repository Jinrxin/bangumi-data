される。","name":"千夜","infobox":[{"key":"简体中文名","value":"千夜"},{"key":"别名","value":[{"k":"纯假名","v":"せんや"}]},{"key":"性别","value":"男"},{"key":"引用来源","value":"https://sengoku-youko.com/character/"}],"stat":{"comments":3,"collects":2},"id":134888,"locked":false,"type":1,"nsfw":false}]}