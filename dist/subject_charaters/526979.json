6QmU.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e1/01/202985_crt_O6QmU.jpg"},"name":"グランヴェ ル男爵夫人","summary":"","relation":"闲角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e0/80/17267_prsn_B1uB6.jpg","grid":"https://lain.bgm.tv/pic/crt/g/e0/80/17267_prsn_B1uB6.jpg","large":"https://lain.bgm.tv/pic/crt/l/e0/80/17267_prsn_B1uB6.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e0/80/17267_prsn_B1uB6.jpg"},"name":"西田望見","short_summary":"西田 望見（にしだ のぞみ、7月22日 - ）は、日本の女性声優、歌手。フリー。レコードレーベルはFlyingDog。岐阜県出身。明治大学卒業生。血液型はA型。\r\n\r\n旧芸名は茅田望見（かやた のぞみ）。2012年までアイドル育成カフェ「AKIHABARAバックステージpass」の1期生として活動していた。また、同年は役者としていくつかの舞台公演に参加している。\r\nもともとアニメや漫画が好きで、制作側に就職することを考えていたが、大学2年生の時に友達から勧められて『CLANNAD』を見た所、人をこんなにも感動させられる作品があるんだと思い、芝居の世界に進もうと決意した。\r\n2014年、TVアニメ『六畳間の侵略者!?』の女子生徒役で声優デビューし、2015年、TVアニメ『アブソリュート・デュオ』で初めて名前のある役を演じた。\r\n2016年4月より放送のTVアニメ『マクロスΔ』にマキナ・中島役で出演。同アニメに出演する女性声優・歌手ら5名によるグループワルキューレのメンバーとして歌唱も担当している。\r\n2018年4月30日をもって声優事務所アトミックモンキーを退所。フリー期間を経て、同年9月1日付でマウスプロモーション所属となった。\r\n2019年4月放送の『八月のシンデレラナイン』でヒロイン有原翼役を演じ、同年7月24日、個人名義のミニアルバムで歌手デビューした。\r\n2021年7月22日、誕生日にでもあるこの日に自身のTwitterにて一般男性と入籍したことを発表。\r\n2021年8月2日、マウスプロモーションを退所し、再びフリーランスとして活動することを発表。","career":["artist","seiyu"],"id":17267,"type":1,"locked":false}],"type":1,"id":202985},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/51/86/203211_crt_w7eyl.jpg","grid":"https://lain.bgm.tv/pic/crt/g/51/86/203211_crt_w7eyl.jpg","large":"https://lain.bgm.tv/pic/crt/l/51/86/203211_crt_w7eyl.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/51/86/203211_crt_w7eyl.jpg"},"name":"リッケル","summary":"","relation":"闲角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/65/99/27806_prsn_j32s3.jpg?r=1492653916","grid":"https://lain.bgm.tv/pic/crt/g/65/99/27806_prsn_j32s3.jpg?r=1492653916","large":"https://lain.bgm.tv/pic/crt/l/65/99/27806_prsn_j32s3.jpg?r=1492653916","medium":"https://lain.bgm.tv/r/400/pic/crt/l/65/99/27806_prsn_j32s3.jpg?r=1492653916"},"name":"虎島貴明","short_summary":"ムーブマン所属。\r\n\r\n