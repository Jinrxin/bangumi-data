/206866_crt_ar1pM.jpg","large":"https://lain.bgm.tv/pic/crt/l/00/b6/206866_crt_ar1pM.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/00/b6/206866_crt_ar1pM.jpg"},"name":"前髪ほっぺちゃん","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/03/71/38711_prsn_3jhnz.jpg?r=1593055089","grid":"https://lain.bgm.tv/pic/crt/g/03/71/38711_prsn_3jhnz.jpg?r=1593055089","large":"https://lain.bgm.tv/pic/crt/l/03/71/38711_prsn_3jhnz.jpg?r=1593055089","medium":"https://lain.bgm.tv/r/400/pic/crt/l/03/71/38711_prsn_3jhnz.jpg?r=1593055089"},"name":"楠賢将","short_summary":"趣味として歌、ショッピング、ダンスをそれぞれ挙げている。特技としてサッカーとバスケットボールをそれぞれ挙げている","career":["seiyu"],"id":38711,"type":1,"locked":false}],"type":1,"id":206866},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/3b/33/206884_crt_z3w99.jpg","grid":"https://lain.bgm.tv/pic/crt/g/3b/33/206884_crt_z3w99.jpg","large":"https://lain.bgm.tv/pic/crt/l/3b/33/206884_crt_z3w99.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/3b/33/206884_crt_z3w99.jpg"},"name":"フォーチュンほっぺちゃん","summary":"","relation":"配角","actors":[],"type":1,"id":206884},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/6c/46/206885_crt_KUu9U.jpg","grid":"https://lain.bgm.tv/pic/crt/g/6c/46/206885_crt_KUu9U.jpg","large":"https://lain.bgm.tv/pic/crt/l/6c/46/206885_crt_KUu9U.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6c/46/206885_crt_KUu9U.jpg"},"name":"甲斐梨子","summary":"","relation":"配角","actors":[],"type":1,"id":206885},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/42/84/206886_crt_mWmw4.jpg","grid":"https://lain.bgm.tv/pic/crt/g/42/84/206886_crt_mWmw4.jpg","large":"https://lain.bgm.tv/pic/crt/l/42/84/206886_crt_mWmw4.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/42/84/206886_crt_mWmw4.jpg"},"name":"玉坊主ほっぺちゃん","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/53/fd/25464_prsn_3FnQU.jpg","grid":"https://lain.bgm.tv/pic/crt/g/53/fd/25464_prsn_3FnQU.jpg","large":"https://lain.bgm.tv/pic/crt/l/53/fd/25464_prsn_3FnQU.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/53/fd/25464_prsn_3FnQU.jpg"},"name":"川上晃二","short_summary":"日本の男性声優。岡山県出身。岡山県立井原高等学校、青二塾東京校II部13期卒業。2012年から青二プロダクション（ジュニア）に所属していた。2015年12月に青二プロダクションを退所し、フリー期間を経て2016年4月よりWITH LINEに所属。\r\n2012年より声優として活動。また、「害」名義で音楽サークル「Prototype」の主催を務める。","career":["artist","seiyu"],"id":25464,"type":1,"locked":false}],"type":1,"id":206886},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/c3/56/206887_crt_WrjFB.jpg","grid":"https://lain.bgm.tv/pic/crt/g/c3/56/206887_crt_WrjFB.jpg","large":"https://lain.bgm.tv/pic/crt/l/c3/56/206887_crt_WrjFB.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/c3/56/206887_crt_WrjFB.jpg"},"name":"天童よしみほっぺちゃん","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/34/8f/20529_prsn_qbVv7.jpg?r=1448688251","grid":"https://lain.bgm.tv/pic/crt/g/34/8f/20529_prsn_qbVv7.jpg?r=1448688251","large":"https://lain.bgm.tv/pic/crt/l/34/8f/20529_prsn_qbVv7.jpg?r=1448688251","medium":"https://lain.bgm.tv/r/400/pic/crt/l/34/8f/20529_prsn_qbVv7.jpg?r=1448688251"},"name":"天童よしみ","short_summary":"天童芳美（天童よしみ，1954年9月26日－），本名吉田芳美，是日本的演歌歌手。出生于和歌山县田边市芳养町。属于日本艺能界其中一名重量级的资深歌手。\r\n\r\n自少受到热唱歌的父亲所影响，4岁时由出生地搬至大阪府八尾市，7岁时已经作公开表现，最先于电视节目中亮相，被称赞为“可爱的Baby”（可爱いベイビー），及后亦参加了多个才艺比赛，兼且曾获胜。\r\n\r\n先后在八尾市立龙华小学校、八尾市立龙华中学校毕业。\r\n\r\n1970年，参加了由富士电视台所举办的歌唱比赛后，获当时节目监制推荐下，加入了日本哥伦比亚，后来又因同台的动画“いなかっぺ大将”中演唱了主题歌“大ちゃん数え呗／いなかっぺ大将”，9月10日，以“吉田芳美”（吉田よしみ）的名称推出了第一张单曲。\r\n\r\n1972年，参加了由读卖电视台所举行的“全日本歌谣选手赛”，获得了连续10周长胜纪录，亦成为当时年纪最轻的总冠军。\r\n\r\n然而，自此却经历了超过10年的低沉期，因而曾考虑过退出艺能界，幸得父母的支持才得以留住。1985年12月转投至Teichiku 娱乐，推出了单曲《道顿堀人情》，因这曲亦是镜五郎同年1月时所推出的单曲，天童芳美的大碟推出市面后，曾录得1个月的全国销售量只有300只的纪录，为此，她不断出席各类访问及演出，以提高知名度，渐渐地她的演译受到了好评，此曲亦成为她日后事业的转捩点。1993年，首次出战NHK红白歌合战。而1996年所推出的《珍岛物语》获得了超过130万张的销售额，成为了她首张获得“百万唱片”荣誉的唱片，同年更夺得日本唱片大赏最优秀歌曲奖。\r\n\r\n除了歌唱事业外，天童芳美亦有参与电影、电视剧及电影配音等工作。","career":["artist"],"id":20529,"type":1,"locked":false}],"type":1,"id":206887},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/af/10/206895_crt_016xQ.jpg","grid":"https://lain.bgm.tv/pic/crt/g/af/10/206895_crt_016xQ.jpg","large":"https://lain.bgm.tv/pic/crt/l/af/10/206895_crt_016xQ.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/af/10/206895_crt_016xQ.jpg"},"name":"ZENほっぺちゃん","summary":"","relation":"配角","actors":[],"type":1,"id":206895},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/c2/33/206896_crt_1WptJ.jpg","grid":"https://lain.bgm.tv/pic/crt/g/c2/33/206896_crt_1WptJ.jpg","large":"https://lain.bgm.tv/pic/crt/l/c2/33/206896_crt_1WptJ.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/c2/33/206896_crt_1WptJ.jpg"},"name":"AIプラックチーク","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/22/74/8479_prsn_OzG18.jpg?r=1715868631","grid":"https://lain.bgm.tv/pic/crt/g/22/74/8479_prsn_OzG18.jpg?r=1715868631","large":"https://lain.bgm.tv/pic/crt/l/22/74/8479_prsn_OzG18.jpg?r=1715868631","medium":"https://lain.bgm.tv/r/400/pic/crt/l/22/74/8479_prsn_OzG18.jpg?r=1715868631"},"name":"能登有沙","short_summary":"千叶县出身的艺人、声优。STYLE CUBE所属的女性声优组合StylipS成员。，Hello! pro EGG的前成员。音乐Gatas的前成员。身高153cm。血型是AB型。官方昵称是“のっち”。\r\n\r\n2002年。11月10日 写真集「エンジェルBOOKS 6 - Water melon 〜関あおい・能登有沙・川前光代・村田歩美写真集」が心交社より発売された。\r\n2003年，9月29日 同日から放送を開始したNHK月曜ドラマシリーズ「夢みる葡萄〜本を読む女〜」に出演した。\r\n2004年，ハロプロ エッグ オーディション2004に合格し、ハロプロエッグの一員となる。\r\n2005年，1月、Hello!Projectコンサートツアーの東京公演にバックダンサーとして登場。初のお披露目となる。後日発売された同コンサートの写真集に能登を含むハロプロエッグ20人の名前がローマ字表記で記載されている。10月8日から10日にかけて行われたイベント「『モーニング娘。“熱っちぃ地球を冷ますんだっ。”文化祭2005』in 横浜」で「ともいき・木を植えたい」のお披露目が行われた。\r\n2006年，3月、公式ブログ「ともいき・木を植えたい」日記開始。7月、「ともいき・木を植えたい」がHAND IN HANDの応援歌である「みんなの木」を歌う事が発表された。\r\n2007年，4月、東京の女子短期大学に入学。6月19日、Gatas Brilhantes H.P.のメンバーとなることが発表された。9月12日、「音楽ガッタス」名義でのGatas Brilhantes H.P.のデビューシングル『鳴り始めた恋のBELL』に参加。\r\n2008年，2月6日、「音楽ガッタス」の1stアルバム『1st GOODSAL』に参加。3月30日、HAPPY! STYLEのメンバーが発表され、Communication Circuit 001に参加することが発表された。6月29日、石川梨華、嗣永桃子とともに動画チャンネル「ドガドガ7」に参加することが発表され、7月1日からはYouTubeによる動画配信が開始された。7月1日、公式ブログのタイトルが、「のっちブログ」から「癒され日和」に変更されリニューアルされるとともに、趣味の欄にアニメ鑑賞、マンガが追記される。12月29日、コミックマーケット75にて枝川みるる、坂田奈穂子（HAPPY! STYLE Rookies）と共に同人誌「ザ ドガドガ」を販売。\r\n2009年，4月、女子短大から四年制大学の三年次に編入。4月1日、オフィシャルファンクラブ分割に伴い、公式ブログがハロプロエッグオフィシャルファンクラブページ内に移動。8月10日、ハロー!プロジェクト新人公演9月〜横浜JUMP!〜をもってハロプロエッグを卒業、アップフロントエッグに移動することを発表。また、ブログも8月10日からファンクラブ限定からアメブロへ移動。8月15日、コミックマーケット76にて、同人誌「ザ・ドガドガ 創刊弐號」ならびにDVD「ドガドガ７〜好きなラーメンは何味ですか?〜」を販売。9月23日、ハロプロエッグを卒業、アップフロントエッグの一員となる。12月30日、コミックマーケット77にてポートレートブック「ARi01」ならびにオリジナルミニアルバム「NO NIGHT EDEN」を販売。\r\n2010年，11月23日、初台The DOORSにてアニメソングを対象とした100曲ライブ「アリスタ！スペシャル〜アニソン100曲ライブ〜」を開催。\r\n2011年，3月、大学を卒業。4月23日、高田馬場 CLUB PHASEにてハロー!プロジェクトの楽曲を対象とした100曲ライブ「能登有沙100曲ライブ phase-II 100 HELLO!」を開催。7月、アップフロントスタイルからスタイルキューブに所属事務所を移籍。以降、ハロー!プロジェクト及びアップフロントエッグの一員としての活動がなくなる。12月、StylipSのメンバーの一員として活動開始。\r\n2018年，12月31日、离开Style Cube, 加入Solid Cube。\r\n2024年，2月27日、結婚\r\n\r\n个人生活\r\n自身の所属するStylipSでは振り付けを担当しており、アニメ作品内でのダンスシーンの振り付けやモーションアクターとしての活動も多い。小倉・石原、および松永の脱退により、現在では同ユニット発足当初からの唯一のメンバーとなっている。\r\n3人兄弟の長女。弟が2人いる。\r\n飼っているペットは「ハント」（チワワとポメラニアンのミックス）\r\n趣味は、カラオケ、切手収集（使用済み切手集め）、お絵かき、アニメ鑑賞、マンガ、ネットサーフィン。\r\n特技は、書道（幼稚園から習っており、毛筆五段で高等師範免許も持っている、硬筆三段）、パソコンの早打ち。また、書道だけでなく絵も得意としており、2008年5-6月には公式ブログでハロプロエッグのメンバー全員の似顔絵を公開していた。\r\n自他問わず耳たぶを触るのが癖。\r\n好きな食べ物は、エビフライ、うどんであり、苦手な食べ物は、白身魚（ホッケ、カレイなど）、タルタルソース。\r\n自分のことを「あり」と呼ぶ。ブログでは「ぁり」と表記している。\r\n是永美記をみきちゃんと呼ぶ。二人は仲が良く、是永の誕生日のコメントもしている。\r\n憧れの先輩は石川梨華。\r\n新選組ファンである。中でもお気に入りは土方歳三。\r\n好きなアニメに「機動戦士ガンダム00」を挙げており、各キャラクターの説明などが書かれた自作ノートを作成していた。\r\nのもぴ〜プラスティックラジオなどを通じてガンプラ制作に本格的に取り組んでいる。ヲタク女子を取り上げた書籍「ヲ乙女図鑑」では『ヲ乙女スタイル：ガンプラ・アニメ』となっている。","career":["artist","seiyu","actor"],"id":8479,"type":1,"locked":false}],"type":1,"id":206896},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/cc/33/206897_crt_KFtkP.jpg","grid":"https://lain.bgm.tv/pic/crt/g/cc/33/206897_crt_KFtkP.jpg","large":"https://lain.bgm.tv/pic/crt/l/cc/33/206897_crt_KFtkP.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/cc/33/206897_crt_KFtkP.jpg"},"name":"シ・スターほっぺちゃん","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/10