pg","grid":"https://lain.bgm.tv/pic/crt/g/09/a8/42619_prsn_5DYHX.jpg","large":"https://lain.bgm.tv/pic/crt/l/09/a8/42619_prsn_5DYHX.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/09/a8/42619_prsn_5DYHX.jpg"},"name":"浦和希","short_summary":"出身地\t大阪府\r\n方言\t関西弁\r\n趣味・特技\t趣味：サッカー、トロンボーン\r\n特技：ゲームプレイ\r\n資格\tCGエンジニア検定エキスパート、第三級陸上特殊無線技士\r\n芸歴\t日本ナレーション演技研究所","career":["seiyu"],"id":42619,"type":1,"locked":false}],"type":1,"id":200459},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/44/6c/200460_crt_nbg0G.jpg","grid":"https://lain.bgm.tv/pic/crt/g/44/6c/200460_crt_nbg0G.jpg","large":"https://lain.bgm.tv/pic/crt/l/44/6c/200460_crt_nbg0G.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/44/6c/200460_crt_nbg0G.jpg"},"name":"猫の魔女","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/a4/de/17981_prsn_gMWIZ.jpg?r=1616944577","grid":"https://lain.bgm.tv/pic/crt/g/a4/de/17981_prsn_gMWIZ.jpg?r=1616944577","large":"https://lain.bgm.tv/pic/crt/l/a4/de/17981_prsn_gMWIZ.jpg?r=1616944577","medium":"https://lain.bgm.tv/r/400/pic/crt/l/a4/de/17981_prsn_gMWIZ.jpg?r=1616944577"},"name":"藤田茜","short_summary":"藤田 茜（ふじた あかね、1993年1月26日 - ）は、日本の女性声優。賢プロダクション所属。静岡県出身。賢プロダクション全国声優オーディション2011準グランプリ受賞。\r\n趣味は、競技かるた・手芸・カフェ巡り。また、インドア派である。\r\n小学生の頃から本を声に出して読むことが大好きで、高校時代は放送部で朗読をしていた。三年次にはNHK杯全国高校放送コンテストの全国大会に出場した。ラジオから声優を好きになることが多く、田村ゆかりや小野坂昌也の番組を聞いていたという。\r\n学生時代、「あねご」と呼ばれていた。\r\n座右の銘は「何とかなるさ」。2015年5月現在、ひとり暮らしをしている。\r\n賢プロダクションの声優によるユニット『VvoxX』のメンバー。儚さ担当、不思議担当。","career":["seiyu"],"id":17981,"type":1,"locked":false}],"type":1,"id":200460},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/b9/c9/201163_crt_JKL5I.jpg","grid":"https://lain.bgm.tv/pic/crt/g/b9/c9/201163_crt_JKL5I.jpg","large":"https://lain.bgm.tv/pic/crt/l/b9/c9/201163_crt_JKL5I.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/b9/c9/201163_crt_JKL5I.jpg"},"name":"コウモリの魔法使い","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/2f/8b/19514_prsn_900cz.jpg","grid":"https://lain.bgm.tv/pic/crt/g/2f/8b/19514_prsn_900cz.jpg","large":"https://lain.bgm.tv/pic/crt/l/2f/8b/19514_prsn_900cz.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/2f/8b/19514_prsn_900cz.jpg"},"name":"熊谷健太郎","short_summary":"熊谷 健太郎（くまがい けんたろう、1994年2月16日 - ）は、日本の男性声優。埼玉県生まれ、沖縄県出身。ヒューマンアカデミー卒業。東京俳優生活協同組合所属。\r\n\r\n埼玉県生まれの3人兄弟の長男。小学校に入学するタイミングで沖縄本島中部の町へ引っ越し、19歳まで住んでいた。\r\n総合学園ヒューマンアカデミー卒業後、2014年、俳協ボイスアクターズスタジオに第45期生として入所。2015年、東京俳優生活協同組合に所属。\r\n\r\n普通自動車免許に加え、PADIオープンダイバーとP検3級の資格も持っている。小学校から中学校まではサッカーをしていた。\r\n『アイドルマスター SideM』の握野英雄役で初めてオーディションに合格した。\r\n天﨑滉平とはアニメの初現場から現場が一緒になることが多く、アイドルマスターSideMの公開録音でもステージに一緒に立てて、幸せだと語っている。","career":["seiyu"],"id":19514,"type":1,"locked":false}],"type":1,"id":201163},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/af/86/201164_crt_pKKWK.jpg","grid":"https://lain.bgm.tv/pic/crt/g/af/86/201164_crt_pKKWK.jpg","large":"https://lain.bgm.tv/pic/crt/l/af/86/201164_crt_pKKWK.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/af/86/201164_crt_pKKWK.jpg"},"name":"ネズミの魔法使い","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e2/e6/20631_prsn_bTC2c.jpg","grid":"https://lain.bgm.tv/pic/crt/g/e2/e6/20631_prsn_bTC2c.jpg","large":"https://lain.bgm.tv/pic/crt/l/e2/e6/20631_prsn_bTC2c.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e2/e6/20631_prsn_bTC2c.jpg"},"name":"小市眞琴","short_summary":"小市真琴是日本的女性声优、舞台演员、编舞家，东京都出身。隶属于stay luck。","career":["seiyu","actor"],"id":20631,"type":1,"locked":false}],"type":1,"id":201164},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/c8/cf/201165_crt_l8LNL.jpg","grid":"https://lain.bgm.tv/pic/crt/g/c8/cf/201165_crt_l8LNL.jpg","large":"https://lain.bgm.tv/pic/crt/l/c8/cf/201165_crt_l8LNL.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/c8/cf/201165_crt_l8LNL.jpg"},"name":"リゼルの母","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/da/21/3943_seiyu_anidb.jpg","grid":"https://lain.bgm.tv/pic/crt/g/da/21/3943_seiyu_anidb.jpg","large":"https://lain.bgm.tv/pic/crt/l/da/21/3943_seiyu_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/da/21/3943_seiyu_anidb.jpg"},"name":"園崎未恵","short_summary":"日本の声優、女優、ナレーター、歌手。リマックス所属。愛称は、みけ、おそのさん。\r\n\r\n東京都出身。身長155.5cm、血液型はA型。以前の芸名はそのざきみえ。\r\n\r\n在芭蕾舞教师母亲的教导下，小学入学时开始学习古典芭蕾舞剧。高中（女子学校）戏剧部所属。专科毕业后，俳协演剧研究所入所。老师是手冢敏夫。1994年3月同所毕业。毕业后从事舞台音响相关的工作，有电视剧临时演员和模特的经验。此后正式开始解说的工作。\r\n1996年，移籍至TAB Production。开始了声优的道路。\r\n1997年，以“そのざきみえ”为艺名作为声优出道。\r\n1999年1月，退出TAB Production。同年4月加入Remax。\r\n2002年4月1日，艺名表记改为汉字的“园崎未惠”。\r\n2008年11月8日，宣布结婚。\r\n2013年12月30日，经过4年半的婚姻生活后离婚。","career":["artist","seiyu"],"id":3943,"type":1,"locked":false}],"type":1,"id":201165},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d8/9d/201166_crt_zvOIY.jpg","grid":"https://lain.bgm.tv/pic/crt/g/d8/9d/201166_crt_zvOIY.jpg","large":"https://lain.bgm.tv/pic/crt/l/d8/9d/201166_crt_zvOIY.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d8/9d/201166_crt_zvOIY.jpg"},"name":"王妃","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/13/90/5487_seiyu_anidb.jpg","grid":"https://lain.bgm.tv/pic/crt/g/13/90/5487_seiyu_anidb.jpg","large":"https://lain.bgm.tv/pic/crt/l/13/90/5487_seiyu_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/13/90/5487_seiyu_anidb.jpg"},"name":"樋口あかり","short_summary":"勝田声優学院、俳協ボイスアクターズスタジオを経て東京俳優生活協同組合に所属。\r\n2008年4月1日より、東京俳優生活協同組合からアクロス エンタテインメントに移籍。\r\n2011年2月28日、アクロス エンタテインメントを退所。","career":["seiyu"],"id":5487,"type":1,"locked":false}],"type":1,"id":201166},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/90/db/203236_crt_ECFCA.jpg","grid":"https://lain.bgm.tv/pic/crt/g/90/db/203236_crt_ECFCA.jpg","large":"https://lain.bgm.tv/pic/crt/l/90/db/203236_crt_ECFCA.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/90/db/203236_crt_ECFCA.jpg"},"name":"ランスロット","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/75/9c/31361_prsn_GOy7L.jpg","grid":"htt