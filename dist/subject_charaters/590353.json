ge":"https://lain.bgm.tv/pic/crt/l/6e/ee/185946_crt_n52jC.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6e/ee/185946_crt_n52jC.jpg"},"name":"下呂アカリ","summary":"下呂の妹。解毒が得意。","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/a9/6f/18600_prsn_LGgtC.jpg?r=1585323843","grid":"https://lain.bgm.tv/pic/crt/g/a9/6f/18600_prsn_LGgtC.jpg?r=1585323843","large":"https://lain.bgm.tv/pic/crt/l/a9/6f/18600_prsn_LGgtC.jpg?r=1585323843","medium":"https://lain.bgm.tv/r/400/pic/crt/l/a9/6f/18600_prsn_LGgtC.jpg?r=1585323843"},"name":"白石晴香","short_summary":"日本の女優、声優。\r\n特长：爵士舞、芭蕾、花道、书法、舞蹈、足球。\r\n\r\n2007年より女優として活動し、舞台などに出演。2011年に『コクリコ坂から』の松崎空役で声優デビュー。\r\n2019年12月31日，退出ヒラタオフィス事务所\r\n2020年1月1日开始作为自由声优活动并开设了新的Twitter帐号（shiraharu48）。\r\n2020年6月1日开始进入TOY'S FACTORY(トイズファクトリー)事务所。","career":["seiyu","actor"],"id":18600,"type":1,"locked":false}],"type":1,"id":185946},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/cc/ea/185947_crt_dCo6x.jpg","grid":"https://lain.bgm.tv/pic/crt/g/cc/ea/185947_crt_dCo6x.jpg","large":"https://lain.bgm.tv/pic/crt/l/cc/ea/185947_crt_dCo6x.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/cc/ea/185947_crt_dCo6x.jpg"},"name":"花巻トシキ","summary":"『蟲使い』一族の当主で下呂の友人。","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/dd/fd/21652_prsn_XRwXr.jpg","grid":"https://lain.bgm.tv/pic/crt/g/dd/fd/21652_prsn_XRwXr.jpg","large":"https://lain.bgm.tv/pic/crt/l/dd/fd/21652_prsn_XRwXr.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/dd/fd/21652_prsn_XRwXr.jpg"},"name":"祐仙勇","short_summary":"誕生日：1月10日\r\n出身地：大阪府\r\n方言：関西弁\r\n趣味・特技：料理、バイク","career":["seiyu"],"id":21652,"type":1,"locked":false}],"type":1,"id":185947},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/10/7b/185949_crt_L2862.jpg","grid":"https://lain.bgm.tv/pic/crt/g/10/7b/185949_crt_L2862.jpg","large":"https://lain.bgm.tv/pic/crt/l/10/7b/185949_crt_L2862.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/10/7b/185949_crt_L2862.jpg"},"name":"潮雫","summary":"『水使い』。裏社会のビジネスマン。\r\n非常にビジネスライクな性格で、仕事は徹底的にこなす。いつも潜水スーツを身にまとっている。","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/aa/cd/4769_prsn_hII7Z.jpg?r=1687855320","grid":"https://lain.bgm.tv/pic/crt/g/aa/cd/4769_prsn_hII7Z.jpg?r=1687855320","large":"https://lain.bgm.tv/pic/crt/l/aa/cd/4769_prsn_hII7Z.jpg?r=1687855320","medium":"https://lain.bgm.tv/r/400/pic/crt/l/aa/cd/4769_prsn_hII7Z.jpg?r=1687855320"},"name":"伊瀬茉莉也","short_summary":"小时候非常喜欢宫崎骏先生的作品，比如《风之谷》什么的，看了很多遍把录像带磨坏了。大约小学3年级左右，看了《幽灵公主》之后非常希望能够加入到里面，做出能让人感动的作品。那个时候光看这部动画就去了电影院8次，一开始是想当监督，后来偶然地有配音机会，便开始走上声优的道路。\r\n一开始父母强烈反对，后来茉莉也对他们描绘了心中的梦想，用“这是我必须去做的事”和“学费自己来付”说服了他们。那时拿出了从小学开始存的压岁钱【好心痛～（笑）】。一开始非常困难，一边要上学一边又要去2小时车程以外的培训中心，但是靠毅力坚持下来之后父母也开始变得支持了，后来嘛，就好了。\r\n第一次工作是在16岁那年，在动画片《愛してるぜベイベ★★》中饰演一个路人角色，台词也只有一两句，但那个时候紧张得不行，拿着剧本的手一直在发抖。后来在比较广为人知的《虫师》中配小孩子的声音，慢慢地工作就多了起来。","career":["seiyu"],"id":4769,"type":1,"locked":false}],"type":1,"id":185949},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/0d/08/185950_crt_7DxoA.jpg","grid":"https://lain.bgm.tv/pic/crt/g/0d/08/185950_crt_7DxoA.jpg","large":"https://lain.bgm.tv/pic/crt/l/0d/08/185950_crt_7DxoA.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/0d/08/185950_crt_7DxoA.jpg"},"name":"鳴子弦弥","summary":"一子相伝『音使い』の末裔。独特の空気感とワードセンスを持つ。\r\n超絶イケメンで女性にモテる。業をつかうためにはリラックスが必要なため、独自で数々のリラクゼーション方法を編み出している。","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/8c/e3/14604_prsn_b1xVh.jpg?r=1758100707","grid":"https://lain.bgm.tv/pic/crt/g/8c/e3/14604_prsn_b1xVh.jpg?r=1758100707","large":"https://lain.bgm.tv/pic/crt/l/8c/e3/14604_prsn_b1xVh.jpg?r=1758100707","medium":"https://lain.bgm.tv/r/400/pic/crt/l/8c/e3/14604_prsn_b1xVh.jpg?r=1758100707"},"name":"斉藤壮馬","short_summary":"高校生活に入って環境の変化に馴染めず、しばらく学校に行っていなかった時期があった。自宅で映画やアニメを見て過ごす時間の中で、『ぼくらの』の石田彰の演技をきっかけに、画面の「向こう側」への憧れを抱いていったという。\r\n2008年に第2回81オーディションに参加し、優秀賞を受賞。\r\n2009年に行われた第33回全国高等学校総合文化祭において、朗読部門にて審査員特別賞を受賞。\r\n高校卒業後、早稲田大学文学部に進学。大学生活に加え、声優の養成所に通っての練習、仕事、さらに慣れない一人暮らしなど、全てをバランス良く続けられなくなったと判断したため、一旦学業に専念し、大学3年の時養成所に通い直した。\r\n大学での勉強が一段落してきた大学4年の頃、声優の仕事を本格的に始めた。2014年春より放送されたテレビアニメ『ハイキュー!!』にて山口忠役を務め注目を集める。同年夏に放送された『アカメが斬る!』のタツミ役、『残響のテロル』のツエルブ（久見冬二）役で初主演を果たす。\r\n2015年、第9回声優アワード新人男優賞を受賞。\r\n2017年、ソロアーティストとしてSACRA MUSICよりデビュー。","career":["artist","seiyu"],"id":14604,"type":1,"locked":false}],"type":1,"id":185950},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/8f/8b/185951_crt_edr5E.jpg","grid":"https://lain.bgm.tv/pic/crt/g/8f/8b/185951_crt_edr5E.jpg","large":"https://lain.bgm.tv/pic/crt/l/8f/8b/185951_crt_edr5E.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/8f/8b/185951_crt_edr5E.jpg"},"name":"中川桃壱","summary":"一般人だが『使い手』以上の実力を持つ突然変異。情報処理能力が飛び抜けて高く、超人的な運動能力も併せ持つ。\r\n1日10時間以上寝ないと調子が出ないが、寝れば怪我も不調も大体治る。殺し屋の素質だけなら現代における最高峰の一人。","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/14/23/24428_prsn_38f98.jpg","grid":"https://lain.bgm.tv/pic/crt/g/14/23/24428_prsn_38f98.jpg","large":"https://lain.bgm.tv/pic/crt/l/14/23/24428_prsn_38f98.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/14/23/24428_prsn_38f98.jpg"},"name":"土屋神葉","short_summary":"土屋 神葉（つちや しんば、1996年4月4日 - ）は、日本の声優、俳優。東京都出身。","career":["seiyu","actor"],"id":24428,"type":1,"locked":false}],"type":1,"id":185951},{"images":{"small":"","grid":"","large":"","medium":""},"name":"板橋トモヒサ","summary":"","relation":"闲角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/1a/4b/3955_prsn_YCKdG.jpg?r=1553254153","grid":"https://lain.bgm.tv/pic/crt/g/1a/4b/3955_prsn_YCKdG.jpg?r=1553254153","large":"https://lain.bgm.tv/pic/crt/l/1a/4b/3955_prsn_YCKdG.jpg?r=1553254153","medium":"https://lain.bgm.tv/r/400/pic/crt/l/1a/4b/3955_prsn_YCKdG.jpg?r=1553254153"},"name":"吉野裕行","short_summary":"日本の男性声優、歌手、ナレーターである。らえら所属。千葉県出身。身長163cm、血液型はB型。","career":["artist","seiyu"],"id":3955,"type":1,"locked":false}],"type":1,"id":207955},{"images":{"small":"","grid":"","large":"","medium":""},"name":"板橋ヨウスケ","summary":"","relation":"闲角","actors":[{"images