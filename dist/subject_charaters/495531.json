t/g/32/f9/201885_crt_v9G30.jpg","large":"https://lain.bgm.tv/pic/crt/l/32/f9/201885_crt_v9G30.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/32/f9/201885_crt_v9G30.jpg"},"name":"ナヴァロ","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/02/71/35289_prsn_VG302.jpg?r=1566111317","grid":"https://lain.bgm.tv/pic/crt/g/02/71/35289_prsn_VG302.jpg?r=1566111317","large":"https://lain.bgm.tv/pic/crt/l/02/71/35289_prsn_VG302.jpg?r=1566111317","medium":"https://lain.bgm.tv/r/400/pic/crt/l/02/71/35289_prsn_VG302.jpg?r=1566111317"},"name":"及川いぞう","short_summary":"及川 いぞう（おいかわ いぞう、1960年3月5日 - ）は、日本の俳優・声優。旧芸名は及川 以造。本名は須郷 哲司（すごう てつじ）。山口県出身。桐朋学園芸術短期大学演劇科卒業。劇団昭和芸能舎所属。所属事務所は愛企画。","career":["seiyu","actor"],"id":35289,"type":1,"locked":false}],"type":1,"id":201885},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/f6/97/201886_crt_bbG7z.jpg","grid":"https://lain.bgm.tv/pic/crt/g/f6/97/201886_crt_bbG7z.jpg","large":"https://lain.bgm.tv/pic/crt/l/f6/97/201886_crt_bbG7z.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/f6/97/201886_crt_bbG7z.jpg"},"name":"リナレス","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e0/b2/4174_prsn_bEaF0.jpg?r=1618428435","grid":"https://lain.bgm.tv/pic/crt/g/e0/b2/4174_prsn_bEaF0.jpg?r=1618428435","large":"https://lain.bgm.tv/pic/crt/l/e0/b2/4174_prsn_bEaF0.jpg?r=1618428435","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e0/b2/4174_prsn_bEaF0.jpg?r=1618428435"},"name":"沢海陽子","short_summary":"新潟县出身。血型O型。在2005年2月11日与配音员大塚明夫结婚，于2008年2月离婚。","career":["seiyu","actor"],"id":4174,"type":1,"locked":false}],"type":1,"id":201886},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/c8/d9/203775_crt_t2zKm.jpg","grid":"https://lain.bgm.tv/pic/crt/g/c8/d9/203775_crt_t2zKm.jpg","large":"https://lain.bgm.tv/pic/crt/l/c8/d9/203775_crt_t2zKm.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/c8/d9/203775_crt_t2zKm.jpg"},"name":"ロニー","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/31/8e/25325_prsn_r6YCb.jpg","grid":"https://lain.bgm.tv/pic/crt/g/31/8e/25325_prsn_r6YCb.jpg","large":"https://lain.bgm.tv/pic/crt/l/31/8e/25325_prsn_r6YCb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/31/8e/25325_prsn_r6YCb.jpg"},"name":"菊池康弘","short_summary":"日本の俳優、声優。岩手県花巻市出身。RME所属。以前はアドヴァンスプロモーションに所属していた。","career":["seiyu","actor"],"id":25325,"type":1,"locked":false}],"type":1,"id":203775},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/74/6a/203776_crt_2CHLj.jpg","grid":"https://lain.bgm.tv/pic/crt/g/74/6a/203776_crt_2CHLj.jpg","large":"https://lain.bgm.tv/pic/crt/l/74/6a/203776_crt_2CHLj.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/74/6a/203776_crt_2CHLj.jpg"},"name":"モリス・ウィリアムズ","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/95/31/4112_prsn_1zQ6k.jpg","grid":"https://lain.bgm.tv/pic/crt/g/95/31/4112_prsn_1zQ6k.jpg","large":"https://lain.bgm.tv/pic/crt/l/95/31/4112_prsn_1zQ6k.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/95/31/4112_prsn_1zQ6k.jpg"},"name":"立木文彦","short_summary":"立木 文彦（たちき ふみひこ、本名同じ、1961年4月29日 - ）は、日本の男性声優、ナレーターである。既婚。2017年現在は大沢事務所に所属している。なお、愛称としては「ぶんちゃん」や「ふーみん」などがある。\r\n\r\n1961年4月29日(土)に、長崎県南松浦郡（現：五島市）で生まれた。声優としてのデビュー作品は、1983年のテレビアニメ『聖戦士ダンバイン』と本人は答えているが、実際にはその前番組『戦闘メカ ザブングル』に脇役として既に出演している。以降、日本のアニメやゲームで声を当てる以外にも、海外の映画やアニメの吹き替えや、CMやテレビ番組のナレーションなども行っていく。\r\n\r\n音楽活動\r\nTAKADA BANDの名義で三松亜美と共に、テレビアニメ『BLUE SEED』のオープニングテーマ『カルナバル・バベル』や、CDアルバム『3×3EYES』を発表したこともあった。また2003年には森川智之とともにヴォーカルユニット2HEARTSを結成し、音楽CDを発表したり、ライブ活動なども行っている。\r\n\r\n所属事務所の変遷\r\nかつてはトルバドール音楽事務所に所属していたが、大沢事務所へと移籍した。\r\n\r\nエピソード\r\n立木は、特に総合格闘技イベントPRIDEのナレーターとしてはよく知られているが、フジテレビジョンのPRIDE放送撤退を受けて、PRIDEの煽りVTRのナレーションから遠ざかっていた時期もある。しかし、2006年11月5日に行われたPRIDE 武士道 -其の十三-にてPRIDEのナレーターとして復帰した。この際にはオープニングVTR内で「ナレーション 立木文彦」の文字を画面いっぱいに表示され、会場で歓声が上がった。当日の第1試合「ゲガール・ムサシVSヘクター・ロンバード」の紹介VTR内で、「NARRATION FUMIHIKO TACHIKI」の文字テロップとともに立木が自己紹介させられる場面があった。スポーツイベントにおいて、このようにナレーターを行っている人物にスポットを当てることは極めて稀なことであるが、立木の場合にはそれが行われた。\r\nナレーションを務めている『世界の果てまでイッテQ』の2012年最後の放送となった大忘年会祭り4時間生放送スペシャル内で行われた「お祭り男が挑む横浜・赤レンガ倉庫前での豊橋手筒花火」にて自身初の生放送番組への出演と生ナレーションに挑戦した。\r\nゲーム「New みんなのGOLF」でゲンゾウがキャディの時にナイスショットを打つと、「世界の果てまで！」と掛け声が流れる。","career":["seiyu"],"id":4112,"type":1,"locked":false}],"type":1,"id":203776},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d8/c6/203777_crt_MFIkh.jpg","grid":"https://lain.bgm.tv/pic/crt/g/d8/c6/203777_crt_MFIkh.jpg","large":"https://lain.bgm.tv/pic/crt/l/d8/c6/203777_crt_MFIkh.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d8/c6/203777_crt_MFIkh.jpg"},"name":"カイル・フォスター","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/6b/5a/46997_prsn_5r0MH.jpg?r=1658006336","grid":"https://lain.bgm.tv/pic/crt/g/6b/5a/46997_prsn_5r0MH.jpg?r=1658006336","large":"https://lain.bgm.tv/pic/crt/l/6b/5a/46997_prsn_5r0MH.jpg?r=1658006336","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6b/5a/46997_prsn_5r0MH.jpg?r=1658006336"},"name":"渡部俊樹","short_summary":"渡部 俊樹（わたなべ としき、9月8日 - ）は、日本の男性声優。東京都出身。アクセント所属。","career":["seiyu"],"id":46997,"type":1,"locked":false}],"type":1,"id":203777},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/ad/4c/205650_crt_0vQ3q.jpg","grid":"https://lain.bgm.tv/pic/crt/g/ad/4c/205650_crt_0vQ3q.jpg","large":"https://lain.bgm.tv/pic/crt/l/ad/4c/205650_crt_0vQ3q.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/ad/4c/205650_crt_0vQ3q.jpg"},"name":"グレイス","summary":"","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/6e/43/14155_prsn_91XYC.jpg","grid":"https://lain.bgm.tv/pic/crt/g/6e/43/14155_prsn_91XYC.jpg","large":"https://lain.bgm.tv/pic/crt/l/6e/43/14155_prsn_91XYC.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/6e/43/14155_prsn_91XYC.jpg"},"name":"中根久美子","short_summary":"出身地\t福島県\r\n方言\tいわき弁\r\n生年月日\t8月18日\r\n血液型\tO型\r\n身長\t148cm\r\n趣味\t動物の観察、歌\r\n特技\t動物の声帯模写\r\n \t \r\n経歴\tプロ・フィット声優養成所　卒","career":["seiyu"],"id":14155,"type":1,"locked":false}],"t