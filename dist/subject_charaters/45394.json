/l/65/16/3989_seiyu_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/65/16/3989_seiyu_anidb.jpg"},"name":"鈴置洋孝","short_summary":"日本の声優、俳優、ナレーターであり、劇団プロデューサー。\r\n\r\n愛知県名古屋市出身、東京経済大学卒業。身長166 cm、体重59kg。血液型はA型。","career":["seiyu"],"id":3989,"type":1,"locked":false}],"type":1,"id":9110},{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d8/f0/16206_crt_46CRz.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/d8/f0/16206_crt_46CRz.jpg","large":"https://lain.bgm.tv/pic/crt/l/d8/f0/16206_crt_46CRz.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d8/f0/16206_crt_46CRz.jpg"},"name":"トランクス","relation":"配角","actors":[{"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e8/b4/4115_prsn_28x5x.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/e8/b4/4115_prsn_28x5x.jpg","large":"https://lain.bgm.tv/pic/crt/l/e8/b4/4115_prsn_28x5x.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e8/b4/4115_prsn_28x5x.jpg"},"name":"草尾毅","short_summary":"","career":["artist","seiyu"],"id":4115,"type":1,"locked":false}],"type":1,"id":16206}],"detail":[{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/48/cb/9110_crt_anidb.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/48/cb/9110_crt_anidb.jpg","large":"https://lain.bgm.tv/pic/crt/l/48/cb/9110_crt_anidb.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/48/cb/9110_crt_anidb.jpg"},"summary":"","name":"天津飯","infobox":[{"key":"性别","value":"男"},{"key":"别名","value":[{"k":"罗马字","v":"Tenshinhan"},{"k":"日文名","v":"天津飯"},{"k":"纯假名","v":"てんしんはん"}]},{"key":"引用来源","value":"anidb.net"},{"key":"身高","value":"187"},{"key":"体重","value":"75"}],"stat":{"comments":1,"collects":4},"id":9110,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"male","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/d8/f0/16206_crt_46CRz.jpg","grid":"https://lain.bgm.tv/r/200/pic/crt/l/d8/f0/16206_crt_46CRz.jpg","large":"https://lain.bgm.tv/pic/crt/l/d8/f0/16206_crt_46CRz.jpg","medium":"https://lain.bgm.tv/r/400/pic/crt/l/d8/f0/16206_crt_46CRz.jpg"},"summary":"其名字来自一种叫作Trunks的男用短裤。他是赛亚人王子贝吉塔与地球人布尔玛所生的混血儿，因此能变身成超级赛亚人。与孙悟天融合后成为悟天克斯，并能变身成超级赛亚人3。\r\n\r\n未来世界的特兰克斯在《龙珠Z》人造人篇时登场。登场时年龄为17岁，14岁因为师父孙悟饭（未来）被人造人17号和18号杀死而在极度愤怒的状况下变身超级赛亚人（动画原创剧情）。\r\n\r\n为了寻找对付在未来世界肆虐的人造人17号和18号的方法，乘坐时光机（由未来世界的布尔玛制造）回到20年前的时空。一出场便把弗利萨父子秒杀，之后把自己的身世告诉孙悟空，并给他治疗心脏病的药使孙悟空不用因心脏病逝世。三年后重返，为了对付沙鲁，与贝吉塔一同于精神时间房修练。后来被超级完全体沙鲁一击杀死，后得到地球神龙复活。沙鲁被杀死后返回未来，因为之前曾经在精神时间房修练过，因此实力大增，可以把人造人17号和18号，以及沙鲁（未来世界、第1形态）消灭。\r\n\r\n《七龙珠Z》人造人篇时登场。原作漫画于第330话，电视动画于《七龙珠Z》第119话初登场。初出场时为短发，后头发变长两次，最后再次剪发。\r\n\r\n现代版同样初登场于人造人篇，当时为一婴孩。魔人布欧篇时与孙悟天一样，无需经过愤怒即可自由变身成超级赛亚人（与未来特兰克斯不同）。后来于第25届天下第一武道会少年组击败孙悟天得到冠军。之后为了消灭布欧与孙悟天一同学习融合，但后来与孙悟天一同被布欧吸收。虽然之后获孙悟空和贝吉塔所救，但是在（纯粹）布欧毁灭地球时死去，后来得到那美克星神龙复活。\r\n\r\n于《七龙珠GT》中与孙悟空和小芳乘坐太空船到宇宙寻找终极七龙珠。曾被贝比附身，虽然贝比很快离开，但贝比在他的身上产卵并被其控制，之后回复原状后，与孙悟饭、孙悟天和小芳一同帮孙悟空恢复能量。\r\n\r\n婴儿版\r\n《七龙珠Z》西鲁篇时登场，婴儿时期的特兰克斯。原作漫画于第337话，电视动画于《七龙珠Z》第126话初登场。\r\n\r\n儿童版\r\n为未来的青年版的童年样貌，为《七龙珠Z》魔人布欧篇与孙悟天同时出场。\r\n\r\n青年版\r\n与未来青年版的样貌比较则较为年轻一点但大致相同，出现于《七龙珠GT》。\r\n\r\n年表（未来版） [編集]エイジ766年 - 誕生。半年後、他の戦士と同様にベジータが人造人間との戦いで死亡し、母子家庭になる。\r\nエイジ779年（13歳） - 悟飯に弟子入り。原作では、トランクスは既に超サイヤ人に覚醒している。同年に人造人間との戦いで悟飯がトランクスを庇い、左腕を失う。\r\nエイジ780年（14歳） - 更にその後、再び出現した人造人間と戦おうとするが、戦士全滅を防ごうとした悟飯に気絶させられる。結局、その戦いで悟飯は死亡[5]。\r\nエイジ784年 - （17歳[6]） - 修行で自信をつけ人造人間に挑むが、返り討ちにあう。アニメでは序盤はいい勝負だったものの、体力が落ちてくると一方的な展開となり、痛めつけられて重傷を負う。そのことで過去へ行くことを決意し、回復後に悟空に特効薬を渡すべくエイジ764年へ。タイムマシンに「Hope〈希望）」と書き、現代の悟空らに人造人間の存在と自身の正体を教え[7]心臓病の薬を渡すため、そして父であるベジータに会うために旅立つ。フリーザ親子を倒した後、悟空に特効薬を渡し未来へ帰る。\r\nエイジ785年（18歳） - その数ヵ月後、エイジ767年5月12日へ行く。悟空達に協力する中、精神と時の部屋でパワーアップ。しかしパワーに頼った変身をしたため、完全体となったセルに敵わず、欠点を指摘された後、戦意を喪失。\r\nセルゲームの最中でセルに殺されるも、ドラゴンボールの力で生き返る。その過去での戦いが終わった翌日、未来へ戻り人造人間を破壊。\r\nエイジ788年（22歳） - 人造人間の破壊から3年後、過去へ向かおうとしていたセルを倒す。\r\n\r\n年表（現代版） [編集]エイジ766年 - 誕生。\r\nエイジ773年（7歳） - 超サイヤ人に覚醒。\r\nエイジ774年（8歳） - 第25回天下一武道会、少年の部優勝。\r\nその後魔人ブウとの戦いで死亡するが、ドラゴンボールで生き返る。\r\nエイジ784年（18歳） - 第28回天下一武道会に参加。","name":"トランクス","infobox":[{"key":"简