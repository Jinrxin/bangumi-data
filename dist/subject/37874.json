{"bangumi":{"date":"2009-05-24","platform":"OVA","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/39/66/37874_qB06C.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/39/66/37874_qB06C.jpg","large":"https://lain.bgm.tv/pic/cover/l/39/66/37874_qB06C.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/39/66/37874_qB06C.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/39/66/37874_qB06C.jpg"},"summary":"在光坂高中空无一人的教室内，藤林椋终于鼓起勇气向被人当作不良少年的冈崎朋也表白。幸运的是，她的爱意没有落于虚空，得到了冈崎热情而肯定的回应。两人自此开始交往，望着沉浸在幸福中的妹妹，藤林杏心中自是无法道出的复杂感受。某个明媚的假日，冈崎和杏在公园不期而遇。杏半开玩笑地教冈崎把自己当作椋练习接吻，谁知这一幕却被同学看见，第二天便在学校内传得风言风语。为了消除谣言，杏甚至假装和春原阳平交往。甜蜜又青涩的学生时代，说不清道不明的爱恋情怀……","name":"CLANNAD 〜AFTER STORY〜もうひとつの世界 杏編","name_cn":"CLANNAD ～AFTER STORY～另一个世界 杏篇","tags":[{"name":"OVA","count":2,"total_cont":0},{"name":"恋爱","count":2,"total_cont":0},{"name":"校园","count":2,"total_cont":0},{"name":"京阿尼","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"游戏改","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"CLANNAD ～AFTER STORY～另一个世界 杏篇"},{"key":"话数","value":"1"},{"key":"发售日","value":"2009年5月24日"},{"key":"原作","value":"Key/VISUAL ARTS"},{"key":"导演","value":"石原立也"},{"key":"脚本","value":"志茂文彦"},{"key":"人物设定","value":"池田和美"},{"key":"演出助理","value":"石立太一"},{"key":"作画监督","value":"高橋真梨子"},{"key":"原画","value":"浦田芳憲、植野千世子、紫藤晃由、大藤佐恵子、池田さやか、大橋勇吾、中川淳、水谷有吾、河浪栄作、佐藤達也、内海紘子、門脇未来、柏木平、高橋真梨子"},{"key":"动画检查","value":"藤田奈緒子"},{"key":"色彩指定","value":"竹田明代"},{"key":"上色检查","value":"竹田明代"},{"key":"制作管理","value":"瀬波里梨"}],"rating":{"rank":720,"total":8283,"count":{"1":21,"2":6,"3":18,"4":45,"5":182,"6":760,"7":2721,"8":3242,"9":770,"10":518},"score":7.6},"total_episodes":1,"collection":{"on_hold":180,"dropped":64,"wish":1462,"collect":15170,"doing":184},"id":37874,"eps":1,"meta_tags":["校园","恋爱","日本","OVA","游戏改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"bangumiData":{"title":"CLANNAD ～AFTER STORY～もうひとつの世界 杏編","titleTranslate":{"zh-Hans":["CLANNAD ～AFTER STORY～另一个世界 杏篇"]},"type":"ova","lang":"ja