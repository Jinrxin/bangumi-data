{"bangumi":{"date":"1976-01-02","platform":"TV","images":{"small":"https://lain.bgm.tv/r/200/pic/cover/l/16/6d/148631_X9i7h.jpg","grid":"https://lain.bgm.tv/r/100/pic/cover/l/16/6d/148631_X9i7h.jpg","large":"https://lain.bgm.tv/pic/cover/l/16/6d/148631_X9i7h.jpg","medium":"https://lain.bgm.tv/r/800/pic/cover/l/16/6d/148631_X9i7h.jpg","common":"https://lain.bgm.tv/r/400/pic/cover/l/16/6d/148631_X9i7h.jpg"},"summary":"　文豪マーク・トウェインが著した児童文学の古典『トム・ソーヤの冒険』の姉妹編が原作。制作は『まんが日本昔話』『タッチ』等のグループ・タック。腕白児童ハックルベリィ（ハック）・フィンは親友トム・ソーヤと別れて冒険の旅に出る。相棒は黒人奴隷のジムだ。少年ながら奴隷制度に反対のハックは、リベラルな法律のカイロ州に向かい、心を通わすジムを自由にしたかった。だがジムがハックを殺したと誤解した人々が追撃を始めた。","name":"ハックルベリィの冒険","name_cn":"哈克历险记","tags":[{"name":"小说改","count":2,"total_cont":0},{"name":"TV","count":2,"total_cont":0},{"name":"旧物","count":1,"total_cont":0},{"name":"在电视上断断续续看过","count":1,"total_cont":0},{"name":"1976","count":1,"total_cont":0},{"name":"童年向","count":1,"total_cont":0},{"name":"日本","count":1,"total_cont":0},{"name":"腾讯","count":1,"total_cont":0}],"infobox":[{"key":"中文名","value":"哈克历险记"},{"key":"别名","value":[{"v":"哈克贝利·费恩历险记"},{"v":"顽童历险记"},{"v":"The Adventures of Huckleberry Finn"},{"v":"Huckleberry no Bouken"}]},{"key":"话数","value":"26"},{"key":"放送开始","value":"1976年1月2日"},{"key":"放送星期","value":"星期五"},{"key":"播放结束","value":"1976年6月25日"}],"rating":{"rank":0,"total":1,"count":{"1":0,"2":0,"3":0,"4":0,"5":1,"6":0,"7":0,"8":0,"9":0,"10":0},"score":5},"total_episodes":26,"collection":{"on_hold":3,"dropped":6,"wish":8,"collect":8,"doing":1},"id":148631,"eps":26,"meta_tags":["TV","日本","小说改"],"volumes":0,"series":false,"locked":false,"nsfw":false,"type":2},"bangumiData":{"title":"ハックルベリィの冒険","titleTranslate":{"zh-Hans":["哈克历险记"]},"type":"tv","lang":"ja","officialSite":"","begin":"1976-01-02T16:00:00.000Z","end":"1976-06-25T16:30:00.000Z","sites":[{"site":"qq","id":"8/8szu83s4qj0z4o0","begin":""},{"site":"bangumi","id":"148631"},{"site":"tmdb","id":"tv/96615"},{"site":"mal","id":"2545"},{"site":"anidb","id":"3388"},{"site":"aniList","id":"25